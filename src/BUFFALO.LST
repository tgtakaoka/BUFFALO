    1538/ E7A3:                ;**********
    1539/ E7A3:                ;*  dump [<addr1> [<addr2>]]  - Dump memory
    1540/ E7A3:                ;* in 16 byte lines from <addr1> to <addr2>.
    1541/ E7A3:                ;*   Default starting address is "current
    1542/ E7A3:                ;* location" and default number of lines is 8.
    1543/ E7A3:                ;**********
    1544/ E7A3:                ;*ptr1 = ptrmem;        /* default start address */
    1545/ E7A3:                ;*ptr2 = ptr1 + $80;    /* default end address */

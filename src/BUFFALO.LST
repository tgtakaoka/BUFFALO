    4110/ F9EA:
    4111/ F9EA:
    4112/ F9EA:
    4113/ F9EA:                ;**********
    4114/ F9EA:                ;*   call [<addr>] - Execute a jsr to <addr> or user
    4115/ F9EA:                ;*pc value.  Return to monitor via  rts or breakpoint.
    4116/ F9EA:                ;**********
    4117/ F9EA:                ;*a = wskip();
    4118/ F9EA:                ;*if(a != cr)
    4119/ F9EA:                ;*     a = buffarg();
    4120/ F9EA:                ;*     a = wskip();
    4121/ F9EA:                ;*     if(a != cr) return(bad argument)
    4122/ F9EA:                ;*     pc = shftreg;
    4123/ F9EA: BD E2 FC       CALL            JSR   WSKIP
    4124/ F9ED: 27 13                          BEQ   CALL3           ;jump if no arg
    4125/ F9EF: BD E2 34                       JSR   BUFFARG
    4126/ F9F2: BD E2 FC                       JSR   WSKIP
    4127/ F9F5: 27 07                          BEQ   CALL2           ;jump if cr
    4128/ F9F7: CE E6 98                       LDX   #MSG9           ;"bad argument"
    4129/ F9FA: BD E5 05                       JSR   OUTSTRG
    4130/ F9FD: 39                             RTS
    4131/ F9FE: DE 96          CALL2           LDX   SHFTREG
    4132/ FA00: DF 60                          STX   REGS            ;pc = <addr>
    4133/ FA02:
    4134/ FA02:                ;*put return address on user stack
    4135/ FA02:                ;*setbps();
    4136/ FA02:                ;*restack();     /* restack and go*/
    4137/ FA02: DE 69          CALL3           LDX   SP
    4138/ FA04: 09                             DEX                   ;user stack pointer
    4139/ FA05: CC FA 16                       LDD   #RETURN         ;return address
    4140/ FA08: ED 00                          STD   0,X
    4141/ FA0A: 09                             DEX
    4142/ FA0B: DF 69                          STX   SP              ;new user stack pointer
    4143/ FA0D: BD FA 87                       JSR   SETBPS
    4144/ FA10: 7F 00 C1                       CLR   TMP2            ;1=go, 0=call
    4145/ FA13: 7E FB 72                       JMP   RESTACK         ;go to user code
    4146/ FA16:
    4147/ FA16:                ;**********
    4148/ FA16:                ;*   return() - Return here from rts after
    4149/ FA16:                ;*call command.
    4150/ FA16:                ;**********
    4151/ FA16: 36             RETURN          PSHA                  ;save a register
    4152/ FA17: 07                             TPA
    4153/ FA18: 97 68                          STAA  REGS+8          ;cc register
    4154/ FA1A: 0F                             SEI                   ;mask interrupts
    4155/ FA1B: 32                             PULA
    4156/ FA1C: DD 66                          STD   REGS+6          ;a and b registers
    4157/ FA1E: DF 64                          STX   REGS+4          ;x register
    4158/ FA20: 18 DF 62                       STY   REGS+2          ;y register
    4159/ FA23: 9F 69                          STS   SP              ;user stack pointer
    4160/ FA25: 9E B2                          LDS   PTR2            ;monitor stack pointer
    4161/ FA27: BD FA B4                       JSR   REMBPS          ;remove breakpoints
    4162/ FA2A: BD E4 F5                       JSR   OUTCRLF
    4163/ FA2D: BD E1 F3                       JSR   RPRINT          ;print user registers
    4164/ FA30: 39                             RTS
    4165/ FA31:
    4166/ FA31:
    4167/ FA31:                ;**********
    4168/ FA31:                ;*   proceed - Same as go except it ignores
    4169/ FA31:                ;*a breakpoint at the first opcode.  Calls
    4170/ FA31:                ;*runone for the first instruction only.
    4171/ FA31:                ;**********
    4172/ FA31: =$FA31         PROCEED         EQU   *
    4173/ FA31: BD FB 56                       JSR   RUNONE          ;run one instruction
    4174/ FA34: BD E3 1F                       JSR   CHKABRT         ;check for abort
    4175/ FA37: 7F 00 C1                       CLR   TMP2            ;flag for breakpoints
    4176/ FA3A: 7C 00 C1                       INC   TMP2            ;  1=go 0=call
    4177/ FA3D: BD FA 87                       JSR   SETBPS
    4178/ FA40: 7E FB 72                       JMP   RESTACK         ;go execute
    4179/ FA43:
    4180/ FA43:                ;**********
    4181/ FA43:                ;*   go [<addr>] - Execute starting at <addr> or
    4182/ FA43:                ;*user's pc value.  Executes an rti to user code.
    4183/ FA43:                ;*Returns to monitor via an swi through swiin.
    4184/ FA43:                ;**********
    4185/ FA43:                ;*a = wskip();
    4186/ FA43:                ;*if(a != cr)
    4187/ FA43:                ;*     a = buffarg();
    4188/ FA43:                ;*     a = wskip();
    4189/ FA43:                ;*     if(a != cr) return(bad argument)
    4190/ FA43:                ;*     pc = shftreg;
    4191/ FA43:                ;*setbps();
    4192/ FA43:                ;*restack();     /* restack and go*/
    4193/ FA43: BD E2 FC       GO              JSR   WSKIP
    4194/ FA46: 27 13                          BEQ   GO2             ;jump if no arg
    4195/ FA48: BD E2 34                       JSR   BUFFARG
    4196/ FA4B: BD E2 FC                       JSR   WSKIP
    4197/ FA4E: 27 07                          BEQ   GO1             ;jump if cr
    4198/ FA50: CE E6 98                       LDX   #MSG9           ;"bad argument"
    4199/ FA53: BD E5 05                       JSR   OUTSTRG
    4200/ FA56: 39                             RTS
    4201/ FA57: DE 96          GO1             LDX   SHFTREG
    4202/ FA59: DF 60                          STX   REGS            ;pc = <addr>
    4203/ FA5B: 7F 00 C1       GO2             CLR   TMP2
    4204/ FA5E: 7C 00 C1                       INC   TMP2            ;1=go, 0=call
    4205/ FA61: BD FA 87                       JSR   SETBPS
    4206/ FA64: 7E FB 72                       JMP   RESTACK         ;go to user code
    4207/ FA67:
    4208/ FA67:                ;*****
    4209/ FA67:                ;** SWIIN - Breakpoints from go or call commands enter here.
    4210/ FA67:                ;*Remove breakpoints, save user registers, return
    4211/ FA67: =$FA67         SWIIN           EQU   *               ;swi entry point
    4212/ FA67: 30                             TSX                   ;user sp -> x
    4213/ FA68: 9E B2                          LDS   PTR2            ;restore monitor sp
    4214/ FA6A: BD FB 91                       JSR   SAVSTACK        ;save user regs
    4215/ FA6D: BD FA B4                       JSR   REMBPS          ;remove breakpoints from code
    4216/ FA70: DE 60                          LDX   REGS
    4217/ FA72: 09                             DEX
    4218/ FA73: DF 60                          STX   REGS            ;save user pc value
    4219/ FA75:
    4220/ FA75:                ;*if(call command) remove call return addr from user stack;
    4221/ FA75: 7D 00 C1                       TST   TMP2            ;1=go, 0=call
    4222/ FA78: 26 06                          BNE   GO3             ;jump if go command
    4223/ FA7A: DE 69                          LDX   SP              ;remove return address
    4224/ FA7C: 08                             INX                   ; user stack pointer
    4225/ FA7D: 08                             INX
    4226/ FA7E: DF 69                          STX   SP
    4227/ FA80: BD E4 F5       GO3             JSR   OUTCRLF         ;print register values
    4228/ FA83: BD E1 F3                       JSR   RPRINT
    4229/ FA86: 39                             RTS                   ;done
    4230/ FA87:
    4231/ FA87:                ;**********
    4232/ FA87:                ;*  setbps - Replace user code with swi's at
    4233/ FA87:                ;*breakpoint addresses.
    4234/ FA87:                ;**********
    4235/ FA87:                ;*for(b=0; b=6; b =+ 2)
    4236/ FA87:                ;*     x = brktabl[b];
    4237/ FA87:                ;*     if(x != 0)
    4238/ FA87:                ;*          optabl[b] = x[0];
    4239/ FA87:                ;*          x[0] = $3F;
    4240/ FA87:                ;*Put monitor SWI vector into jump table
    4241/ FA87:
    4242/ FA87: 5F             SETBPS          CLRB
    4243/ FA88: CE 00 9C       SETBPS1         LDX   #BRKTABL
    4244/ FA8B: 18 CE 00 B6                    LDY   #PTR4
    4245/ FA8F: 3A                             ABX
    4246/ FA90: 18 3A                          ABY
    4247/ FA92: EE 00                          LDX   0,X             ;breakpoint table entry
    4248/ FA94: 27 0A                          BEQ   SETBPS2         ;jump if 0
    4249/ FA96: A6 00                          LDAA  0,X             ;save user opcode
    4250/ FA98: 18 A7 00                       STAA  0,Y
    4251/ FA9B: 86 3F                          LDAA  #SWI
    4252/ FA9D: BD E2 8A                       JSR   WRITE           ;insert swi into code
    4253/ FAA0: CB 02          SETBPS2         ADDB  #$2
    4254/ FAA2: C1 06                          CMPB  #$6
    4255/ FAA4: 2F E2                          BLE   SETBPS1         ;loop 4 times
    4256/ FAA6: DE F5                          LDX   JSWI+1
    4257/ FAA8: DF B4                          STX   PTR3            ;save user swi vector
    4258/ FAAA: 86 7E                          LDAA  #$7E            ;jmp opcode
    4259/ FAAC: 97 F4                          STAA  JSWI
    4260/ FAAE: CE FA 67                       LDX   #SWIIN
    4261/ FAB1: DF F5                          STX   JSWI+1          ;monitor swi vector
    4262/ FAB3: 39                             RTS
    4263/ FAB4:
    4264/ FAB4:                ;**********
    4265/ FAB4:                ;*   rembps - Remove breakpoints from user code.
    4266/ FAB4:                ;**********
    4267/ FAB4:                ;*for(b=0; b=6; b =+ 2)
    4268/ FAB4:                ;*     x = brktabl[b];
    4269/ FAB4:                ;*     if(x != 0)
    4270/ FAB4:                ;*          x[0] = optabl[b];
    4271/ FAB4:                ;*Replace user's SWI vector
    4272/ FAB4: 5F             REMBPS          CLRB
    4273/ FAB5: CE 00 9C       REMBPS1         LDX   #BRKTABL
    4274/ FAB8: 18 CE 00 B6                    LDY   #PTR4
    4275/ FABC: 3A                             ABX
    4276/ FABD: 18 3A                          ABY
    4277/ FABF: EE 00                          LDX   0,X             ;breakpoint table entry
    4278/ FAC1: 27 06                          BEQ   REMBPS2         ;jump if 0
    4279/ FAC3: 18 A6 00                       LDAA  0,Y
    4280/ FAC6: BD E2 8A                       JSR   WRITE           ;restore user opcode
    4281/ FAC9: CB 02          REMBPS2         ADDB  #$2
    4282/ FACB: C1 06                          CMPB  #$6
    4283/ FACD: 2F E6                          BLE   REMBPS1         ;loop 4 times
    4284/ FACF: DE B4                          LDX   PTR3            ;restore user swi vector
    4285/ FAD1: DF F5                          STX   JSWI+1
    4286/ FAD3: 39                             RTS
    4287/ FAD4:
    4288/ FAD4:
    4289/ FAD4:                ;**********
    4290/ FAD4:                ;*   trace <n> - Trace n instructions starting
    4291/ FAD4:                ;*at user's pc value. n is a hex number less than
    4292/ FAD4:                ;*$FF (defaults to 1).
    4293/ FAD4:                ;**********
    4294/ FAD4:                ;*a = wskip();
    4295/ FAD4:                ;*if(a != cr)
    4296/ FAD4:                ;*     a = buffarg(); a = wskip();
    4297/ FAD4:                ;*     if(a != cr) return(bad argument);
    4298/ FAD4:                ;*     countt1 = n
    4299/ FAD4: 7F 00 C3       TRACE           CLR   TMP4
    4300/ FAD7: 7C 00 C3                       INC   TMP4            ;default count=1
    4301/ FADA: 7F 00 A9                       CLR   CHRCNT          ;set up for display
    4302/ FADD: BD E2 FC                       JSR   WSKIP
    4303/ FAE0: 27 13                          BEQ   TRACE2          ;jump if cr
    4304/ FAE2: BD E2 34                       JSR   BUFFARG
    4305/ FAE5: BD E2 FC                       JSR   WSKIP
    4306/ FAE8: 27 07                          BEQ   TRACE1          ;jump if cr
    4307/ FAEA: CE E6 98                       LDX   #MSG9           ;"bad argument"
    4308/ FAED: BD E5 05                       JSR   OUTSTRG
    4309/ FAF0: 39                             RTS
    4310/ FAF1: 96 97          TRACE1          LDAA  SHFTREG+1       ;n
    4311/ FAF3: 97 C3                          STAA  TMP4
    4312/ FAF5:
    4313/ FAF5:                ;*Disassemble the line about to be traced
    4314/ FAF5: =$FAF5         TRACE2          EQU   *
    4315/ FAF5: D6 C3                          LDAB  TMP4
    4316/ FAF7: 37                             PSHB
    4317/ FAF8: DE 60                          LDX   REGS
    4318/ FAFA: DF B0                          STX   PTR1            ;pc value for disass
    4319/ FAFC: BD F3 63                       JSR   DISASSM
    4320/ FAFF: 33                             PULB
    4321/ FB00: D7 C3                          STAB  TMP4
    4322/ FB02:
    4323/ FB02:                ;*run one instruction
    4324/ FB02:                ;*rprint();
    4325/ FB02:                ;*while(count > 0) continue trace;
    4326/ FB02: BD FB 56                       JSR   RUNONE
    4327/ FB05: BD E3 1F                       JSR   CHKABRT         ;check for abort
    4328/ FB08: BD E5 25                       JSR   TABTO           ;print registers for
    4329/ FB0B: BD E1 F3                       JSR   RPRINT          ;   result of trace
    4330/ FB0E: 7A 00 C3                       DEC   TMP4
    4331/ FB11: 27 05                          BEQ   TRACDON         ;quit if count=0
    4332/ FB13: BD E4 F5       TRACE3          JSR   OUTCRLF
    4333/ FB16: 20 DD                          BRA   TRACE2
    4334/ FB18: 39             TRACDON         RTS
    4335/ FB19:
    4336/ FB19:
    4337/ FB19:                ;**********
    4338/ FB19:                ;*   stopat <addr> - Trace instructions until <addr>
    4339/ FB19:                ;*is reached.
    4340/ FB19:                ;**********
    4341/ FB19:                ;*if((a=wskip) != cr)
    4342/ FB19:                ;*     a = buffarg(); a = wskip();
    4343/ FB19:                ;*     if(a != cr) return(bad argument);
    4344/ FB19:                ;*else return(bad argument);
    4345/ FB19: =$FB19         STOPAT          EQU   *
    4346/ FB19: BD E2 FC                       JSR   WSKIP
    4347/ FB1C: 27 18                          BEQ   STOPGO          ;jump if cr - no argument
    4348/ FB1E: BD E2 34                       JSR   BUFFARG
    4349/ FB21: BD E2 FC                       JSR   WSKIP
    4350/ FB24: 27 07                          BEQ   STOPAT1         ;jump if cr
    4351/ FB26: CE E6 98                       LDX   #MSG9           ;"bad argument"
    4352/ FB29: BD E5 05                       JSR   OUTSTRG
    4353/ FB2C: 39                             RTS
    4354/ FB2D: 7D 00 A8       STOPAT1         TST   COUNT
    4355/ FB30: 27 04                          BEQ   STOPGO          ;jump if no argument
    4356/ FB32: DE 96                          LDX   SHFTREG
    4357/ FB34: DF AA                          STX   PTRMEM          ;update "current location"
    4358/ FB36:
    4359/ FB36:                ;*while(!(ptrmem <= userpc < ptrmem+10)) runone();
    4360/ FB36:                ;*rprint();
    4361/ FB36: DC 60          STOPGO          LDD   REGS            ;userpc
    4362/ FB38: 1A 93 AA                       CPD   PTRMEM
    4363/ FB3B: 25 0A                          BLO   STOPNEXT        ;if(userpc < ptrmem) runone
    4364/ FB3D: DC AA                          LDD   PTRMEM
    4365/ FB3F: C3 00 0A                       ADDD  #10
    4366/ FB42: 1A 93 60                       CPD   REGS
    4367/ FB45: 22 08                          BHI   STOPDON         ;quit if ptrmem+10 > userpc
    4368/ FB47: BD FB 56       STOPNEXT        JSR   RUNONE
    4369/ FB4A: BD E3 1F                       JSR   CHKABRT         ;check for abort
    4370/ FB4D: 20 E7                          BRA   STOPGO
    4371/ FB4F: BD E4 F5       STOPDON         JSR   OUTCRLF
    4372/ FB52: BD E1 F3                       JSR   RPRINT          ;result of trace
    4373/ FB55: 39                             RTS                   ;done
    4374/ FB56:
    4375/ FB56:
    4376/ FB56:                ;*************************
    4377/ FB56:                ;* runone - This routine is used by the trace and
    4378/ FB56:                ;* execute commands to run one only one user instruction.
    4379/ FB56:                ;*   Control is passed to the user code via an RTI.  OC5
    4380/ FB56:                ;* is then used to trigger an XIRQ as soon as the first user
    4381/ FB56:                ;* opcode is fetched.  Control then returns to the monitor
    4382/ FB56:                ;* through XIRQIN.
    4383/ FB56:                ;*  Externally, the OC5 pin must be wired to the XIRQ pin.
    4384/ FB56:                ;************************
    4385/ FB56:                ;* Disable oc5 interrupts
    4386/ FB56:                ;* Put monitor XIRQ vector into jump table
    4387/ FB56:                ;* Unmask x bit in user ccr
    4388/ FB56:                ;* Setup OC5 to go low when first user instruction executed
    4389/ FB56: =$FB56         RUNONE          EQU   *
    4390/ FB56: 86 7E                          LDAA  #$7E            ;put "jmp xirqin" in jump table
    4391/ FB58: 97 D3                          STAA  JTOC5
    4392/ FB5A: CE FB 8E                       LDX   #XIRQIN
    4393/ FB5D: DF F2                          STX   JXIRQ+1
    4394/ FB5F: 96 68                          LDAA  REGS+8          ;x bit will be cleared when
    4395/ FB61: 84 BF                          ANDA  #$BF            ;   rti is executed below
    4396/ FB63: 97 68                          STAA  REGS+8
    4397/ FB65: C6 57                          LDAB  #87             ;cycles to end of rti
    4398/ FB67: DE 0E                          LDX   TCNT
    4399/ FB69: 3A                             ABX                   ;                        3~ \
    4400/ FB6A: DF 1E                          STX   TOC5            ;oc5 match register      5~  \
    4401/ FB6C: 96 20                          LDAA  TCTL1           ;                        4~   \
    4402/ FB6E: 84 FE                          ANDA  #$FE            ;set up oc5 low on match 2~    \
    4403/ FB70: 97 20                          STAA  TCTL1           ;enable oc5 interrupt    4~    / 86~
    4404/ FB72:
    4405/ FB72:                ;** RESTACK - Restore user stack and RTI to user code.
    4406/ FB72:                ;* This code is the pathway to execution of user code.
    4407/ FB72:                ;*(Force extended addressing to maintain cycle count)
    4408/ FB72:                ;*Restore user stack and rti to user code
    4409/ FB72: =$FB72         RESTACK         EQU   *               ;68~
    4410/ FB72: BF 00 B2                       STS   >PTR2           ;save monitor sp
    4411/ FB75: BE 00 69                       LDS   >SP             ;user stack pointer
    4412/ FB78: FE 00 60                       LDX   >REGS
    4413/ FB7B: 3C                             PSHX                  ;pc
    4414/ FB7C: FE 00 62                       LDX   >REGS+2
    4415/ FB7F: 3C                             PSHX                  ;y
    4416/ FB80: FE 00 64                       LDX   >REGS+4
    4417/ FB83: 3C                             PSHX                  ;x
    4418/ FB84: FC 00 66                       LDD   >REGS+6
    4419/ FB87: 36                             PSHA                  ;a
    4420/ FB88: 37                             PSHB                  ;b
    4421/ FB89: B6 00 68                       LDAA  >REGS+8
    4422/ FB8C: 36                             PSHA                  ;ccr
    4423/ FB8D: 3B                             RTI
    4424/ FB8E:
    4425/ FB8E:                ;** Return here from run one line of user code.
    4426/ FB8E: =$FB8E         XIRQIN          EQU   *
    4427/ FB8E: 30                             TSX                   ;user sp -> x
    4428/ FB8F: 9E B2                          LDS   PTR2            ;restore monitor sp
    4429/ FB91:
    4430/ FB91:                ;** SAVSTACK - Save user's registers.
    4431/ FB91:                ;* On entry - x points to top of user stack.
    4432/ FB91: =$FB91         SAVSTACK        EQU   *
    4433/ FB91: A6 00                          LDAA  0,X
    4434/ FB93: 97 68                          STAA  REGS+8          ;user ccr
    4435/ FB95: EC 01                          LDD   1,X
    4436/ FB97: 97 67                          STAA  REGS+7          ;b
    4437/ FB99: D7 66                          STAB  REGS+6          ;a
    4438/ FB9B: EC 03                          LDD   3,X
    4439/ FB9D: DD 64                          STD   REGS+4          ;x
    4440/ FB9F: EC 05                          LDD   5,X
    4441/ FBA1: DD 62                          STD   REGS+2          ;y
    4442/ FBA3: EC 07                          LDD   7,X
    4443/ FBA5: DD 60                          STD   REGS            ;pc
    4444/ FBA7: C6 08                          LDAB  #8
    4445/ FBA9: 3A                             ABX
    4446/ FBAA: DF 69                          STX   SP              ;user stack pointer
    4447/ FBAC: 96 20                          LDAA  TCTL1           ;force oc5 pin high which
    4448/ FBAE: 8A 03                          ORAA  #$03            ;  is tied to xirq line
    4449/ FBB0: 97 20                          STAA  TCTL1
    4450/ FBB2: 86 08                          LDAA  #$08
    4451/ FBB4: 97 0B                          STAA  CFORC
    4452/ FBB6: 39                             RTS
    4453/ FBB7:
    4454/ FBB7:
    4455/ FBB7:                ;**********
    4456/ FBB7:                ;*   HOST() - Establishes transparent link between
    4457/ FBB7:                ;*       terminal and host.  Port used for host is
    4458/ FBB7:                ;*       determined in the reset initialization routine
    4459/ FBB7:                ;*       and stored in HOSTDEV.
    4460/ FBB7:                ;*          To exit type control A.
    4461/ FBB7:                ;*          To send break to host type control B.
    4462/ FBB7:                ;*if(no external device) return;
    4463/ FBB7:                ;*initialize host port;
    4464/ FBB7:                ;*While( !(control A))
    4465/ FBB7:                ;*     input(terminal); output(host);
    4466/ FBB7:                ;*     input(host); output(terminal);
    4467/ FBB7:
    4468/ FBB7: 96 A6          HOST            LDAA  EXTDEV
    4469/ FBB9: 26 07                          BNE   HOST0           ;jump if host port avail.
    4470/ FBBB: CE E6 A5                       LDX   #MSG10          ;"no host port avail"
    4471/ FBBE: BD E5 05                       JSR   OUTSTRG
    4472/ FBC1: 39                             RTS
    4473/ FBC2: 7F 00 A4       HOST0           CLR   AUTOLF          ;turn off autolf
    4474/ FBC5: BD E3 3D                       JSR   HOSTCO          ;connect sci (evb board)
    4475/ FBC8: BD FC 27                       JSR   HOSTINIT        ;initialize host port
    4476/ FBCB: BD E3 94       HOST1           JSR   INPUT           ;read terminal
    4477/ FBCE: 4D                             TSTA
    4478/ FBCF: 27 10                          BEQ   HOST3           ;jump if no char
    4479/ FBD1: 81 01                          CMPA  #CTLA
    4480/ FBD3: 27 17                          BEQ   HOSTEND         ;jump if control a
    4481/ FBD5: 81 02                          CMPA  #CTLB
    4482/ FBD7: 26 05                          BNE   HOST2           ;jump if not control b
    4483/ FBD9: BD FB F3                       JSR   TXBREAK         ;send break to host
    4484/ FBDC: 20 03                          BRA   HOST3
    4485/ FBDE: BD FC 3F       HOST2           JSR   HOSTOUT         ;echo to host
    4486/ FBE1: BD FC 33       HOST3           JSR   HOSTIN          ;read host
    4487/ FBE4: 4D                             TSTA
    4488/ FBE5: 27 E4                          BEQ   HOST1           ;jump if no char
    4489/ FBE7: BD E3 BE                       JSR   OUTPUT          ;echo to terminal
    4490/ FBEA: 20 DF                          BRA   HOST1
    4491/ FBEC: 7C 00 A4       HOSTEND         INC   AUTOLF          ;turn on autolf
    4492/ FBEF: BD E3 45                       JSR   TARGCO          ;disconnect sci (evb board)
    4493/ FBF2: 39                             RTS                   ;return
    4494/ FBF3:
    4495/ FBF3:                ;**********
    4496/ FBF3:                ;* txbreak() - transmit break to host port.
    4497/ FBF3:                ;* The duration of the transmitted break is
    4498/ FBF3:                ;* approximately 200,000 E-clock cycles, or
    4499/ FBF3:                ;* 100ms at 2.0 MHz.
    4500/ FBF3:                ;***********
    4501/ FBF3: =$FBF3         TXBREAK         EQU   *
    4502/ FBF3: 96 A7                          LDAA  HOSTDEV
    4503/ FBF5: 81 03                          CMPA  #$03
    4504/ FBF7: 27 0D                          BEQ   TXBDU           ;jump if duartb is host
    4505/ FBF9:
    4506/ FBF9: CE 00 2D       TXBSCI          LDX   #SCCR2          ;sci is host
    4507/ FBFC: 1C 00 01                       BSET  0,X,#01         ;set send break bit
    4508/ FBFF: 8D 1D                          BSR   TXBWAIT
    4509/ FC01: 1D 00 01                       BCLR  0,X,#01         ;clear send break bit
    4510/ FC04: 20 0D                          BRA   TXB1
    4511/ FC06:
    4512/ FC06: CE D0 08       TXBDU           LDX   #PORTB          ;duart host port
    4513/ FC09: 86 60                          LDAA  #$60            ;start break cmd
    4514/ FC0B: A7 02                          STAA  2,X             ;port b command register
    4515/ FC0D: 8D 0F                          BSR   TXBWAIT
    4516/ FC0F: 86 70                          LDAA  #$70            ;stop break cmd
    4517/ FC11: A7 02                          STAA  2,X             ;port b command register
    4518/ FC13:
    4519/ FC13: 86 0D          TXB1            LDAA  #$0D
    4520/ FC15: BD FC 3F                       JSR   HOSTOUT         ;send carriage return
    4521/ FC18: 86 0A                          LDAA  #$0A
    4522/ FC1A: BD FC 3F                       JSR   HOSTOUT         ;send linefeed
    4523/ FC1D: 39                             RTS
    4524/ FC1E:
    4525/ FC1E: 18 CE 6F 9B    TXBWAIT         LDY   #$6F9B          ;loop count = 28571
    4526/ FC22: 18 09          TXBWAIT1        DEY                   ;7 cycle loop
    4527/ FC24: 26 FC                          BNE   TXBWAIT1
    4528/ FC26: 39                             RTS

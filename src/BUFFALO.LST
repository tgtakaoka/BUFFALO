     479/ E1B2: CE 00 9C       BPCLR           LDX   #BRKTABL
     480/ E1B5: C6 08                          LDAB  #8
     481/ E1B7: 6F 00          BPCLR1          CLR   0,X
     482/ E1B9: 08                             INX
     483/ E1BA: 5A                             DECB
     484/ E1BB: 2E FA                          BGT   BPCLR1          ;loop 8 times
     485/ E1BD: 39                             RTS
     486/ E1BE:
     487/ E1BE:                ;*****************
     488/ E1BE:                ;*  RPRNT1(x) - Prints name and contents of a single
     489/ E1BE:                ;* user register. On entry X points to name of register
     490/ E1BE:                ;* in reglist.  On exit, a=register name.
     491/ E1BE:                ;*****************
     492/ E1BE: 50 59 58 41 42 REGLIST         FCC   'PYXABCS'       ;names
     492/ E1C3: 43 53
     493/ E1C5: 00 02 04 06 07                 FCB   0,2,4,6,7,8,9   ;offset
     493/ E1CA: 08 09
     494/ E1CC: 01 01 01 00 00                 FCB   1,1,1,0,0,0,1   ;size
     494/ E1D1: 00 01
     495/ E1D3: A6 00          RPRNT1          LDAA  0,X
     496/ E1D5: 36                             PSHA
     497/ E1D6: 3C                             PSHX
     498/ E1D7: BD E3 BE                       JSR   OUTPUT          ;name
     499/ E1DA: 86 2D                          LDAA  #'-'
     500/ E1DC: BD E3 BE                       JSR   OUTPUT          ;dash
     501/ E1DF: E6 07                          LDAB  7,X             ;contents offset
     502/ E1E1: A6 0E                          LDAA  14,X            ;bytesize
     503/ E1E3: CE 00 60                       LDX   #REGS           ;address
     504/ E1E6: 3A                             ABX
     505/ E1E7: 4D                             TSTA
     506/ E1E8: 27 03                          BEQ   RPRN2           ;jump if 1 byte
     507/ E1EA: BD E4 DD                       JSR   OUT1BYT         ;2 bytes
     508/ E1ED: BD E4 EC       RPRN2           JSR   OUT1BSP
     509/ E1F0: 38                             PULX
     510/ E1F1: 32                             PULA
     511/ E1F2: 39                             RTS
     512/ E1F3:
     513/ E1F3:                ;*****************
     514/ E1F3:                ;*  RPRINT() - Print the name and contents
     515/ E1F3:                ;* of all the user registers.

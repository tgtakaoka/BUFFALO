     107/    0:                ;*     RAM     *
     108/    0:                ;***************
     109/   2D:                                ORG   $2D
     110/   2D:                ;*** Buffalo ram space ***
     111/   2D:                                RMB   20              ;user stack area
     112/   41:                USTACK          RMB   30              ;monitor stack area
     113/   5F:                STACK           RMB   1
     114/   60:                REGS            RMB   9               ;user's pc,y,x,a,b,c
     115/   69:                SP              RMB   2               ;user's sp
     116/   6B:                INBUFF          RMB   BUFFLNG         ;input buffer
     117/   8E: =$8E           ENDBUFF         EQU   *
     118/   8E:                COMBUFF         RMB   8               ;command buffer
     119/   96:                SHFTREG         RMB   2               ;input shift register
     120/   98:                STREE           RMB   2               ;eeprom start address
     121/   9A:                ENDEE           RMB   2               ;eeprom end address
     122/   9C:                BRKTABL         RMB   8               ;breakpoint table
     123/   A4:                AUTOLF          RMB   1               ;auto lf flag for i/o
     124/   A5:                IODEV           RMB   1               ;0=sci,  1=acia, 2=duartA, 3=duartB
     125/   A6:                EXTDEV          RMB   1               ;0=none, 1=acia, 2=duart,
     126/   A7:                HOSTDEV         RMB   1               ;0=sci,  1=acia,           3=duartB
     127/   A8:                COUNT           RMB   1               ;# characters read
     128/   A9:                CHRCNT          RMB   1               ;# characters output on current line
     129/   AA:                PTRMEM          RMB   2               ;current memory location
     130/   AC:                LDOFFST         RMB   2               ;offset for download
     131/   AE:
     132/   AE:                ;*** Buffalo variables - used by: ***
     133/   AE:                PTR0            RMB   2               ;main,readbuff,incbuff,AS
     134/   B0:                PTR1            RMB   2               ;main,BR,DU,MO,AS,EX
     135/   B2:                PTR2            RMB   2               ;EX,DU,MO,AS
     136/   B4:                PTR3            RMB   2               ;EX,HO,MO,AS
     137/   B6:                PTR4            RMB   2               ;EX,AS
     138/   B8:                PTR5            RMB   2               ;EX,AS,BOOT
     139/   BA:                PTR6            RMB   2               ;EX,AS,BOOT
     140/   BC:                PTR7            RMB   2               ;EX,AS
     141/   BE:                PTR8            RMB   2               ;AS
     142/   C0:                TMP1            RMB   1               ;main,hexbin,buffarg,termarg
     143/   C1:                TMP2            RMB   1               ;GO,HO,AS,LOAD
     144/   C2:                TMP3            RMB   1               ;AS,LOAD
     145/   C3:                TMP4            RMB   1               ;TR,HO,ME,AS,LOAD
     146/   C4:                ;*** Vector jump table ***
     147/   C4:                JSCI            RMB   3
     148/   C7:                JSPI            RMB   3
     149/   CA:                JPAIE           RMB   3
     150/   CD:                JPAO            RMB   3
     151/   D0:                JTOF            RMB   3
     152/   D3:                JTOC5           RMB   3
     153/   D6:                JTOC4           RMB   3
     154/   D9:                JTOC3           RMB   3
     155/   DC:                JTOC2           RMB   3
     156/   DF:                JTOC1           RMB   3
     157/   E2:                JTIC3           RMB   3
     158/   E5:                JTIC2           RMB   3
     159/   E8:                JTIC1           RMB   3
     160/   EB:                JRTI            RMB   3
     161/   EE:                JIRQ            RMB   3
     162/   F1:                JXIRQ           RMB   3
     163/   F4:                JSWI            RMB   3
     164/   F7:                JILLOP          RMB   3
     165/   FA:                JCOP            RMB   3
     166/   FD:                JCLM            RMB   3
     167/  100:
     168/  100:                ;*****************
     169/  100:                ;*
     170/  100:                ;* ROM starts here *
     171/  100:                ;*
     172/  100:                ;*****************
     173/  100:
     174/ E000:                                ORG   ROMBS
     175/ E000:
     176/ E000:                ;*****************
     177/ E000:                ;**  BUFFALO - This is where Buffalo starts
     178/ E000:                ;** out of reset.  All initialization is done
     179/ E000:                ;** here including determination of where the
     180/ E000:                ;** user terminal is (SCI,ACIA, or DUART).
     181/ E000:                ;*****************
     182/ E000:
     183/ E000: CE 00 0A       BUFFALO         LDX   #PORTE
     184/ E003: 1F 00 01 03                    BRCLR 0,X,#01,BUFISIT ;if bit 0 of port e is 1
     185/ E007: 7E B6 00                       JMP   DSTREE          ;then jump to the start of EEPROM
     186/ E00A: 86 93          BUFISIT         LDAA  #$93
     187/ E00C: 97 39                          STAA  OPTION          ;adpu, dly, irqe, cop
     188/ E00E: 86 00                          LDAA  #$00
     189/ E010: 97 24                          STAA  TMSK2           ;timer pre = %1 for trace
     190/ E012: 86 00                          LDAA  #$00
     191/ E014: 97 35                          STAA  BPROT           ;clear 'E9 eeprom block protect
     192/ E016: CE B6 00                       LDX   #DSTREE         ;set up default eeprom address range
     193/ E019: DF 98                          STX   STREE
     194/ E01B: CE B7 FF                       LDX   #DENDEE
     195/ E01E: DF 9A                          STX   ENDEE
     196/ E020: CE 00 00                       LDX   #$0000          ;set up default download offset
     197/ E023: DF AC                          STX   LDOFFST
     198/ E025: 8E 00 5F                       LDS   #STACK          ;monitor stack pointer
     199/ E028: BD E3 4D                       JSR   VECINIT
     200/ E02B: CE 00 41                       LDX   #USTACK
     201/ E02E: DF 69                          STX   SP              ;default user stack
     202/ E030: 96 20                          LDAA  TCTL1
     203/ E032: 8A 03                          ORAA  #$03
     204/ E034: 97 20                          STAA  TCTL1           ;force oc5 pin high for trace
     205/ E036: 86 D0                          LDAA  #$D0
     206/ E038: 97 68                          STAA  REGS+8          ;default user ccr
     207/ E03A: CC 3F 0D                       LDD   #$3F0D          ;initial command is ?
     208/ E03D: DD 6B                          STD   INBUFF
     209/ E03F: BD E1 B2                       JSR   BPCLR           ;clear breakpoints
     210/ E042: 7F 00 A4                       CLR   AUTOLF
     211/ E045: 7C 00 A4                       INC   AUTOLF          ;auto cr/lf = on
     212/ E048:
     213/ E048:                ;* Determine type of external comm device - none, or acia *
     214/ E048:
     215/ E048: 7F 00 A6                       CLR   EXTDEV          ;default is none
     216/ E04B: 96 3C                          LDAA  HPRIO
     217/ E04D: 84 20                          ANDA  #$20
     218/ E04F: 27 35                          BEQ   BUFF2           ;jump if single chip mode
     219/ E051: 86 03                          LDAA  #$03            ;see if external acia exists
     220/ E053: B7 DF 00                       STAA  ACIA            ;master reset
     221/ E056: B6 DF 00                       LDAA  ACIA
     222/ E059: 84 7F                          ANDA  #$7F            ;mask irq bit from status register
     223/ E05B: 26 12                          BNE   BUFF1           ;jump if status reg not 0
     224/ E05D: 86 12                          LDAA  #$12
     225/ E05F: B7 DF 00                       STAA  ACIA            ;turn on acia
     226/ E062: B6 DF 00                       LDAA  ACIA
     227/ E065: 84 02                          ANDA  #$02
     228/ E067: 27 06                          BEQ   BUFF1           ;jump if tdre not set
     229/ E069: 86 01                          LDAA  #$01
     230/ E06B: 97 A6                          STAA  EXTDEV          ;external device is acia
     231/ E06D: 20 17                          BRA   BUFF2
     232/ E06F:
     233/ E06F: =$E06F         BUFF1           EQU   *               ;see if duart exists
     234/ E06F: B6 D0 0C                       LDAA  DUART+$0C       ;read IRQ vector register
     235/ E072: 81 0F                          CMPA  #$0F            ;should be out of reset
     236/ E074: 26 10                          BNE   BUFF2
     237/ E076: 86 AA                          LDAA  #$AA
     238/ E078: B7 D0 0C                       STAA  DUART+$0C       ;write irq vector register
     239/ E07B: B6 D0 0C                       LDAA  DUART+$0C       ;read irq vector register
     240/ E07E: 81 AA                          CMPA  #$AA
     241/ E080: 26 04                          BNE   BUFF2
     242/ E082: 86 02                          LDAA  #$02
     243/ E084: 97 A6                          STAA  EXTDEV          ;external device is duart A
     244/ E086:
     245/ E086:                ;* Find terminal port - SCI or external. *
     246/ E086:
     247/ E086: 7F 00 A5       BUFF2           CLR   IODEV
     248/ E089: BD E3 45                       JSR   TARGCO          ;disconnect sci for evb board
     249/ E08C: BD E0 B1                       JSR   SIGNON          ;initialize sci
     250/ E08F: 96 A6                          LDAA  EXTDEV
     251/ E091: 27 05                          BEQ   BUFF3           ;jump if no external device
     252/ E093: 97 A5                          STAA  IODEV
     253/ E095: BD E0 B1                       JSR   SIGNON          ;initialize external device
     254/ E098: 7F 00 A5       BUFF3           CLR   IODEV
     255/ E09B: BD E3 94                       JSR   INPUT           ;get input from sci port
     256/ E09E: 81 0D                          CMPA  #$0D
     257/ E0A0: 27 19                          BEQ   BUFF4           ;jump if cr - sci is terminal port
     258/ E0A2: 96 A6                          LDAA  EXTDEV
     259/ E0A4: 27 F2                          BEQ   BUFF3           ;jump if no external device
     260/ E0A6: 97 A5                          STAA  IODEV
     261/ E0A8: BD E3 94                       JSR   INPUT           ;get input from external device
     262/ E0AB: 81 0D                          CMPA  #$0D
     263/ E0AD: 27 0C                          BEQ   BUFF4           ;jump if cr - terminal found ext
     264/ E0AF: 20 E7                          BRA   BUFF3
     265/ E0B1:
     266/ E0B1: BD E3 6E       SIGNON          JSR   INIT            ;initialize device
     267/ E0B4: CE E6 2D                       LDX   #MSG1           ;buffalo message
     268/ E0B7: BD E5 05                       JSR   OUTSTRG
     269/ E0BA: 39                             RTS
     270/ E0BB:
     271/ E0BB:                ;* Determine where host port should be. *
     272/ E0BB:
     273/ E0BB: 7F 00 A7       BUFF4           CLR   HOSTDEV         ;default - host = sci port
     274/ E0BE: 96 A5                          LDAA  IODEV
     275/ E0C0: 81 01                          CMPA  #$01
     276/ E0C2: 27 04                          BEQ   BUFF5           ;default host if term = acia
     277/ E0C4: 86 03                          LDAA  #$03
     278/ E0C6: 97 A7                          STAA  HOSTDEV         ;else host is duart port b
     279/ E0C8: =$E0C8         BUFF5           EQU   *
     280/ E0C8:
     281/ E0C8:                ;*****************
     282/ E0C8:                ;**  MAIN - This module reads the user's input into
     283/ E0C8:                ;** a buffer called INBUFF.  The first field (assumed
     284/ E0C8:                ;** to be the command field) is then parsed into a
     285/ E0C8:                ;** second buffer called COMBUFF.  The command table
     286/ E0C8:                ;** is then searched for the contents of COMBUFF and
     287/ E0C8:                ;** if found, the address of the corresponding task
     288/ E0C8:                ;** routine is fetched from the command table.  The
     289/ E0C8:                ;** task is then called as a subroutine so that
     290/ E0C8:                ;** control returns back to here upon completion of
     291/ E0C8:                ;** the task.  Buffalo expects the following format
     292/ E0C8:                ;** for commands:
     293/ E0C8:                ;**     <cmd>[<wsp><arg><wsp><arg>...]<cr>
     294/ E0C8:                ;** [] implies contents optional.
     295/ E0C8:                ;** <wsp> means whitespace character (space,comma,tab).
     296/ E0C8:                ;** <cmd> = command string of 1-8 characters.
     297/ E0C8:                ;** <arg> = Argument particular to the command.
     298/ E0C8:                ;** <cr> = Carriage return signifying end of input string.
     299/ E0C8:                ;*****************
     300/ E0C8:                ;* Prompt user
     301/ E0C8:                ;*do
     302/ E0C8:                ;*   a=input();
     303/ E0C8:                ;*   if(a==(cntlx or del)) continue;
     304/ E0C8:                ;*   elseif(a==backspace)
     305/ E0C8:                ;*      b--;
     306/ E0C8:                ;*      if(b<0) b=0;
     307/ E0C8:                ;*   else
     308/ E0C8:                ;*      if(a==cr && buffer empty)
     309/ E0C8:                ;*         repeat last command;
     310/ E0C8:                ;*      else put a into buffer;
     311/ E0C8:                ;*         check if buffer full;
     312/ E0C8:                ;*while(a != (cr or /)
     313/ E0C8: 0F             MAIN            SEI                   ;block interrupts
     314/ E0C9: 8E 00 5F                       LDS   #STACK          ;initialize sp every time
     315/ E0CC: 7F 00 A4                       CLR   AUTOLF
     316/ E0CF: 7C 00 A4                       INC   AUTOLF          ;auto cr/lf = on
     317/ E0D2: BD E4 F5                       JSR   OUTCRLF
     318/ E0D5: 86 3E                          LDAA  #PROMPT         ;prompt user
     319/ E0D7: BD E3 BE                       JSR   OUTPUT
     320/ E0DA: 5F                             CLRB
     321/ E0DB: BD E5 31       MAIN1           JSR   INCHAR          ;read terminal
     322/ E0DE: CE 00 6B                       LDX   #INBUFF
     323/ E0E1: 3A                             ABX                   ;pointer into buffer
     324/ E0E2: 81 18                          CMPA  #CTLX
     325/ E0E4: 27 E2                          BEQ   MAIN            ;jump if cntl X
     326/ E0E6: 81 7F                          CMPA  #DEL
     327/ E0E8: 27 DE                          BEQ   MAIN            ;jump if del
     328/ E0EA: 81 08                          CMPA  #$08
     329/ E0EC: 26 05                          BNE   MAIN2           ;jump if not bckspc
     330/ E0EE: 5A                             DECB
     331/ E0EF: 2D D7                          BLT   MAIN            ;jump if buffer empty
     332/ E0F1: 20 E8                          BRA   MAIN1
     333/ E0F3: 81 0D          MAIN2           CMPA  #$D
     334/ E0F5: 26 07                          BNE   MAIN3           ;jump if not cr
     335/ E0F7: 5D                             TSTB
     336/ E0F8: 27 17                          BEQ   COMM0           ;jump if buffer empty
     337/ E0FA: A7 00                          STAA  0,X             ;put a in buffer
     338/ E0FC: 20 13                          BRA   COMM0
     339/ E0FE: A7 00          MAIN3           STAA  0,X             ;put a in buffer
     340/ E100: 5C                             INCB
     341/ E101: C1 23                          CMPB  #BUFFLNG
     342/ E103: 2F 08                          BLE   MAIN4           ;jump if not long
     343/ E105: CE E6 77                       LDX   #MSG3           ;"long"
     344/ E108: BD E5 05                       JSR   OUTSTRG
     345/ E10B: 20 BB                          BRA   MAIN
     346/ E10D: 81 2F          MAIN4           CMPA  #'/'
     347/ E10F: 26 CA                          BNE   MAIN1           ;jump if not "/"
     348/ E111:                ;*        *******************
     349/ E111:
     350/ E111:                ;*****************
     351/ E111:                ;*  Parse out and evaluate the command field.
     352/ E111:                ;*****************
     353/ E111:                ;*Initialize
     354/ E111:
     355/ E111: =$E111         COMM0           EQU   *
     356/ E111: 7F 00 C0                       CLR   TMP1            ;Enable "/" command
     357/ E114: 7F 00 96                       CLR   SHFTREG
     358/ E117: 7F 00 97                       CLR   SHFTREG+1
     359/ E11A: 5F                             CLRB
     360/ E11B: CE 00 6B                       LDX   #INBUFF         ;ptrbuff[] = inbuff[]
     361/ E11E: DF AE                          STX   PTR0
     362/ E120: BD E2 FC                       JSR   WSKIP           ;find first char
     363/ E123:
     364/ E123:                ;*while((a=readbuff) != (cr or wspace))
     365/ E123:                ;*     upcase(a);
     366/ E123:                ;*     buffptr[b] = a
     367/ E123:                ;*     b++
     368/ E123:                ;*     if (b > 8) error(too long);
     369/ E123:                ;*     if(a == "/")
     370/ E123:                ;*          if(enabled) mslash();
     371/ E123:                ;*          else error(command?);
     372/ E123:                ;*     else hexbin(a);
     373/ E123:
     374/ E123: =$E123         COMM1           EQU   *
     375/ E123: BD E2 E7                       JSR   READBUFF        ;read from buffer

      62/    0:                ;*   EQUATES   *
      63/    0:                ;***************
      64/    0:                ;*Author EQU  Tony Fourcroy
      65/    0: =$0            RAMBS           EQU   $0000           ;start of ram
      66/    0:                ;REGBS   EQU  $1000      ;start of registers
      67/    0: =$0            REGBS           EQU   $0000           ;start of registers
      68/    0: =$E000         ROMBS           EQU   $E000           ;start of rom
      69/    0: =$B600         DSTREE          EQU   $B600           ;start of eeprom
      70/    0: =$B7FF         DENDEE          EQU   $B7FF           ;end of eeprom
      71/    0: =$A            PORTE           EQU   REGBS+$0A       ;port e
      72/    0: =$B            CFORC           EQU   REGBS+$0B       ;force output compare
      73/    0: =$E            TCNT            EQU   REGBS+$0E       ;timer count
      74/    0: =$1E           TOC5            EQU   REGBS+$1E       ;oc5 reg
      75/    0: =$20           TCTL1           EQU   REGBS+$20       ;timer control 1
      76/    0: =$22           TMSK1           EQU   REGBS+$22       ;timer mask 1
      77/    0: =$23           TFLG1           EQU   REGBS+$23       ;timer flag 1
      78/    0: =$24           TMSK2           EQU   REGBS+$24       ;timer mask 2
      79/    0: =$2B           BAUD            EQU   REGBS+$2B       ;sci baud reg
      80/    0: =$2C           SCCR1           EQU   REGBS+$2C       ;sci control1 reg
      81/    0: =$2D           SCCR2           EQU   REGBS+$2D       ;sci control2 reg
      82/    0: =$2E           SCSR            EQU   REGBS+$2E       ;sci status reg
      83/    0: =$2F           SCDAT           EQU   REGBS+$2F       ;sci data reg
      84/    0: =$35           BPROT           EQU   REGBS+$35       ;block protect reg
      85/    0: =$39           OPTION          EQU   REGBS+$39       ;option reg
      86/    0: =$3A           COPRST          EQU   REGBS+$3A       ;cop reset reg
      87/    0: =$3B           PPROG           EQU   REGBS+$3B       ;ee prog reg
      88/    0: =$3C           HPRIO           EQU   REGBS+$3C       ;hprio reg
      89/    0: =$3F           CONFIG          EQU   REGBS+$3F       ;config register
      90/    0: =$4000         DFLOP           EQU   $4000           ;evb d flip flop
      91/    0: =$D000         DUART           EQU   $D000           ;duart address
      92/    0: =$D000         PORTA           EQU   DUART
      93/    0: =$D008         PORTB           EQU   DUART+8
      94/    0:                ;ACIA    EQU  $9800      ;acia address
      95/    0: =$DF00         ACIA            EQU   $DF00           ;acia address
      96/    0: =$3E           PROMPT          EQU   '>'
      97/    0: =$23           BUFFLNG         EQU   35
      98/    0: =$1            CTLA            EQU   $01             ;exit host or assembler
      99/    0: =$2            CTLB            EQU   $02             ;send break to host
     100/    0: =$17           CTLW            EQU   $17             ;wait
     101/    0: =$18           CTLX            EQU   $18             ;abort
     102/    0: =$7F           DEL             EQU   $7F             ;abort
     103/    0: =$4            EOT             EQU   $04             ;end of text/table
     104/    0: =$3F           SWI             EQU   $3F

    4530/ FC27:
    4531/ FC27:                ;**********
    4532/ FC27:                ;*   hostinit(), hostin(), hostout() - host i/o
    4533/ FC27:                ;*routines.  Restores original terminal device.
    4534/ FC27:                ;**********
    4535/ FC27: D6 A5          HOSTINIT        LDAB  IODEV           ;save terminal
    4536/ FC29: 37                             PSHB
    4537/ FC2A: D6 A7                          LDAB  HOSTDEV
    4538/ FC2C: D7 A5                          STAB  IODEV           ;point to host
    4539/ FC2E: BD E3 6E                       JSR   INIT            ;initialize host
    4540/ FC31: 20 16                          BRA   TERMRES         ;restore terminal
    4541/ FC33: D6 A5          HOSTIN          LDAB  IODEV           ;save terminal
    4542/ FC35: 37                             PSHB
    4543/ FC36: D6 A7                          LDAB  HOSTDEV
    4544/ FC38: D7 A5                          STAB  IODEV           ;point to host
    4545/ FC3A: BD E3 94                       JSR   INPUT           ;read host
    4546/ FC3D: 20 0A                          BRA   TERMRES         ;restore terminal
    4547/ FC3F: D6 A5          HOSTOUT         LDAB  IODEV           ;save terminal
    4548/ FC41: 37                             PSHB
    4549/ FC42: D6 A7                          LDAB  HOSTDEV
    4550/ FC44: D7 A5                          STAB  IODEV           ;point to host
    4551/ FC46: BD E3 BE                       JSR   OUTPUT          ;write to host
    4552/ FC49: 33             TERMRES         PULB                  ;restore terminal device
    4553/ FC4A: D7 A5                          STAB  IODEV
    4554/ FC4C: 39                             RTS
    4555/ FC4D:
    4556/ FC4D:
    4557/ FC4D:                ;**********
    4558/ FC4D:                ;*   load(ptrbuff[]) - Load s1/s9 records from
    4559/ FC4D:                ;*host to memory.  Ptrbuff[] points to string in
    4560/ FC4D:                ;*input buffer which is a command to output s1/s9
    4561/ FC4D:                ;*records from the host ("cat filename" for unix).
    4562/ FC4D:                ;*    Returns error and address if it can't write
    4563/ FC4D:                ;*to a particular location.
    4564/ FC4D:                ;**********
    4565/ FC4D:                ;*   verify(ptrbuff[]) - Verify memory from load
    4566/ FC4D:                ;*command.  Ptrbuff[] is same as for load.
    4567/ FC4D:                ;* tmp3 is used as an error indication, 0=no errors,
    4568/ FC4D:                ;* 1=receiver, 2=rom error, 3=checksum error.
    4569/ FC4D:                ;**********
    4570/ FC4D: 7F 00 C1       VERIFY          CLR   TMP2
    4571/ FC50: 7C 00 C1                       INC   TMP2            ;TMP2=1=verify
    4572/ FC53: 20 03                          BRA   LOAD1
    4573/ FC55: 7F 00 C1       LOAD            CLR   TMP2            ;    0=load
    4574/ FC58:
    4575/ FC58:                ;*a=wskip();
    4576/ FC58:                ;*if(a = cr) goto transparent mode;
    4577/ FC58:                ;*if(t option) hostdev = iodev;
    4578/ FC58: =$FC58         LOAD1           EQU   *
    4579/ FC58: 7F 00 C2                       CLR   TMP3            ;clear error flag
    4580/ FC5B: BD E2 FC                       JSR   WSKIP
    4581/ FC5E: 26 03                          BNE   LOAD2
    4582/ FC60: 7E FB B7                       JMP   HOST            ;go to host if no args
    4583/ FC63: BD E1 A7       LOAD2           JSR   UPCASE
    4584/ FC66: 81 54                          CMPA  #'T'            ;look for t option
    4585/ FC68: 26 16                          BNE   LOAD3           ;jump not t option
    4586/ FC6A: BD E2 EE                       JSR   INCBUFF
    4587/ FC6D: BD E2 E7                       JSR   READBUFF        ;get next character
    4588/ FC70: BD E2 F4                       JSR   DECBUFF
    4589/ FC73: 81 0D                          CMPA  #$0D
    4590/ FC75: 26 09                          BNE   LOAD3           ;jump if not t option
    4591/ FC77: 7F 00 A4                       CLR   AUTOLF
    4592/ FC7A: 96 A5                          LDAA  IODEV
    4593/ FC7C: 97 A7                          STAA  HOSTDEV         ;set host port = terminal
    4594/ FC7E: 20 1B                          BRA   LOAD10          ;go wait for s1 records
    4595/ FC80:
    4596/ FC80:                ;*else while(not cr)
    4597/ FC80:                ;*     read character from input buffer;
    4598/ FC80:                ;*     send character to host;
    4599/ FC80: 7F 00 A4       LOAD3           CLR   AUTOLF
    4600/ FC83: BD E3 3D                       JSR   HOSTCO          ;connect sci (evb board)
    4601/ FC86: BD FC 27                       JSR   HOSTINIT        ;initialize host port
    4602/ FC89: BD E2 E7       LOAD4           JSR   READBUFF        ;get next char
    4603/ FC8C: BD E2 EE                       JSR   INCBUFF
    4604/ FC8F: 36                             PSHA                  ;save char
    4605/ FC90: BD FC 3F                       JSR   HOSTOUT         ;output to host
    4606/ FC93: BD E3 BE                       JSR   OUTPUT          ;echo to terminal
    4607/ FC96: 32                             PULA
    4608/ FC97: 81 0D                          CMPA  #$0D
    4609/ FC99: 26 EE                          BNE   LOAD4           ;jump if not cr
    4610/ FC9B:
    4611/ FC9B:                ;*repeat:                           /* look for s records */
    4612/ FC9B:                ;*      if(hostdev != iodev) check abort;
    4613/ FC9B:                ;*      a = hostin();
    4614/ FC9B:                ;*      if(a = 'S')
    4615/ FC9B:                ;*          a = hostin;
    4616/ FC9B:                ;*          if(a = '1')
    4617/ FC9B:                ;*              checksum = 0;
    4618/ FC9B:                ;*              get byte count in b;
    4619/ FC9B:                ;*              get base address in x;
    4620/ FC9B:                ;*              while(byte count > 0)
    4621/ FC9B:                ;*                  byte();
    4622/ FC9B:                ;*                  x++; b--;
    4623/ FC9B:                ;*                  if(tmp3=0)           /* no error */
    4624/ FC9B:                ;*                      if(load) x[0] = shftreg+1;
    4625/ FC9B:                ;*                      if(x[0] != shftreg+1)
    4626/ FC9B:                ;*                          tmp3 = 2;    /* rom error */
    4627/ FC9B:                ;*                          ptr3 = x;    /* save address */
    4628/ FC9B:                ;*              if(tmp3 = 0) do checksum;
    4629/ FC9B:                ;*              if(checksum err) tmp3 = 3; /* checksum error */
    4630/ FC9B:                ;** Look for s-record header
    4631/ FC9B: =$FC9B         LOAD10          EQU   *
    4632/ FC9B: 96 A7                          LDAA  HOSTDEV
    4633/ FC9D: 91 A5                          CMPA  IODEV
    4634/ FC9F: 27 03                          BEQ   LOAD11          ;jump if hostdev=iodev
    4635/ FCA1: BD E3 1F                       JSR   CHKABRT         ;check for abort
    4636/ FCA4: BD FC 33       LOAD11          JSR   HOSTIN          ;read host
    4637/ FCA7: 4D                             TSTA
    4638/ FCA8: 27 F1                          BEQ   LOAD10          ;jump if no input
    4639/ FCAA: 81 53                          CMPA  #'S'
    4640/ FCAC: 26 ED                          BNE   LOAD10          ;jump if not S
    4641/ FCAE: BD FC 33       LOAD12          JSR   HOSTIN          ;read host
    4642/ FCB1: 4D                             TSTA
    4643/ FCB2: 27 FA                          BEQ   LOAD12          ;jump if no input
    4644/ FCB4: 81 39                          CMPA  #'9'
    4645/ FCB6: 27 4E                          BEQ   LOAD90          ;jump if S9 record
    4646/ FCB8: 81 31                          CMPA  #'1'
    4647/ FCBA: 26 DF                          BNE   LOAD10          ;jump if not S1
    4648/ FCBC: 7F 00 C3                       CLR   TMP4            ;clear checksum
    4649/ FCBF:                ;** Get Byte Count and Starting Address
    4650/ FCBF: BD FD 4C                       JSR   BYTE
    4651/ FCC2: D6 97                          LDAB  SHFTREG+1
    4652/ FCC4: C0 02                          SUBB  #$2             ;b = byte count
    4653/ FCC6: BD FD 4C                       JSR   BYTE
    4654/ FCC9: BD FD 4C                       JSR   BYTE
    4655/ FCCC: 37                             PSHB                  ;save byte count
    4656/ FCCD: DC 96                          LDD   SHFTREG
    4657/ FCCF: D3 AC                          ADDD  LDOFFST         ;add offset
    4658/ FCD1: 8F                             XGDX                  ;x = address+offset
    4659/ FCD2: 33                             PULB                  ;restore byte count
    4660/ FCD3: 09                             DEX                   ;condition for loop
    4661/ FCD4:                ;** Get and Store Incoming Data Byte
    4662/ FCD4: BD FD 4C       LOAD20          JSR   BYTE            ;get next byte
    4663/ FCD7: 08                             INX
    4664/ FCD8: 5A                             DECB                  ;check byte count
    4665/ FCD9: 27 1B                          BEQ   LOAD30          ;if b=0, go do checksum
    4666/ FCDB: 7D 00 C2                       TST   TMP3
    4667/ FCDE: 26 BB                          BNE   LOAD10          ;jump if error flagged
    4668/ FCE0: 7D 00 C1                       TST   TMP2
    4669/ FCE3: 26 05                          BNE   LOAD21          ;jump if verify
    4670/ FCE5: 96 97                          LDAA  SHFTREG+1
    4671/ FCE7: BD E2 8A                       JSR   WRITE           ;load only
    4672/ FCEA: A1 00          LOAD21          CMPA  0,X             ;verify ram location
    4673/ FCEC: 27 E6                          BEQ   LOAD20          ;jump if ram ok
    4674/ FCEE: 86 02                          LDAA  #$02
    4675/ FCF0: 97 C2                          STAA  TMP3            ;indicate rom error
    4676/ FCF2: DF B4                          STX   PTR3            ;save error address
    4677/ FCF4: 20 DE                          BRA   LOAD20          ;finish download
    4678/ FCF6:                ;** Get and Test Checksum
    4679/ FCF6: 7D 00 C2       LOAD30          TST   TMP3
    4680/ FCF9: 26 A0                          BNE   LOAD10          ;jump if error already
    4681/ FCFB: 96 C3                          LDAA  TMP4
    4682/ FCFD: 4C                             INCA                  ;do checksum
    4683/ FCFE: 27 9B                          BEQ   LOAD10          ;jump if s1 record okay
    4684/ FD00: 86 03                          LDAA  #$03
    4685/ FD02: 97 C2                          STAA  TMP3            ;indicate checksum error
    4686/ FD04: 20 95                          BRA   LOAD10
    4687/ FD06:
    4688/ FD06:                ;*          if(a = '9')
    4689/ FD06:                ;*              read rest of record;
    4690/ FD06:                ;*              if(tmp3=2) return("[ptr3]");
    4691/ FD06:                ;*              if(tmp3=1) return("rcv error");
    4692/ FD06:                ;*              if(tmp3=3) return("checksum err");
    4693/ FD06:                ;*              else return("done");
    4694/ FD06: BD FD 4C       LOAD90          JSR   BYTE
    4695/ FD09: D6 97                          LDAB  SHFTREG+1       ;b = byte count
    4696/ FD0B: BD FD 4C       LOAD91          JSR   BYTE
    4697/ FD0E: 5A                             DECB
    4698/ FD0F: 26 FA                          BNE   LOAD91          ;loop until end of record
    4699/ FD11: C6 64                          LDAB  #$64
    4700/ FD13: BD E2 DB       LOAD91A         JSR   DLY10MS         ;delay 1 sec -let host finish
    4701/ FD16: 5A                             DECB
    4702/ FD17: 26 FA                          BNE   LOAD91A
    4703/ FD19: BD E3 94                       JSR   INPUT           ;clear comm device
    4704/ FD1C: CC 7E 0D                       LDD   #$7E0D          ;put dummy command in inbuff
    4705/ FD1F: DD 6B                          STD   INBUFF
    4706/ FD21: 7C 00 A4                       INC   AUTOLF          ;turn on autolf
    4707/ FD24: BD E3 45                       JSR   TARGCO          ;disconnect sci (evb)
    4708/ FD27: CE E6 B2                       LDX   #MSG11          ;"done" default msg
    4709/ FD2A: 96 C2                          LDAA  TMP3
    4710/ FD2C: 81 02                          CMPA  #$02
    4711/ FD2E: 26 08                          BNE   LOAD92          ;jump not rom error
    4712/ FD30: CE 00 B4                       LDX   #PTR3
    4713/ FD33: BD E4 E9                       JSR   OUT2BSP         ;address of rom error
    4714/ FD36: 20 13                          BRA   LOAD95
    4715/ FD38: 81 01          LOAD92          CMPA  #$01
    4716/ FD3A: 26 05                          BNE   LOAD93          ;jump not rcv error
    4717/ FD3C: CE E6 D0                       LDX   #MSG14          ;"rcv error"
    4718/ FD3F: 20 07                          BRA   LOAD94
    4719/ FD41: 81 03          LOAD93          CMPA  #$03
    4720/ FD43: 26 03                          BNE   LOAD94          ;jump not checksum error
    4721/ FD45: CE E6 B7                       LDX   #MSG12          ;"checksum error"
    4722/ FD48: BD E5 05       LOAD94          JSR   OUTSTRG
    4723/ FD4B: 39             LOAD95          RTS

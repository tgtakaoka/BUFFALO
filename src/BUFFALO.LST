    2271/ EBF2:
    2272/ EBF2:                ;****************
    2273/ EBF2:                ;*  readln() --- Read input from terminal into buffer
    2274/ EBF2:                ;* until a command character is read (cr,lf,/,^).
    2275/ EBF2:                ;* If more chars are typed than the buffer will hold,
    2276/ EBF2:                ;* the extra characters are overwritten on the end.
    2277/ EBF2:                ;*  On exit: b=number of chars read, a=0 if quit,
    2278/ EBF2:                ;* else a=next command.
    2279/ EBF2:                ;****************
    2280/ EBF2:                ;*for(b==0;b<=bufflng;b++) inbuff[b] = cr;
    2281/ EBF2:

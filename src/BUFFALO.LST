    1777/ E8F0:                ;*******************************************
    1778/ E8F0:                ;*   MEMORY [<addr>]
    1779/ E8F0:                ;*   [<addr>]/
    1780/ E8F0:                ;* Opens memory and allows user to modify the
    1781/ E8F0:                ;*contents at <addr> or the last opened location.
    1782/ E8F0:                ;*    Subcommands:
    1783/ E8F0:                ;* [<data>]<cr>       - Close current location and exit.
    1784/ E8F0:                ;* [<data>]<lf><+>    - Close current and open next.
    1785/ E8F0:                ;* [<data>]<^><-><bs> - Close current and open previous.
    1786/ E8F0:                ;* [<data>]<sp>       - Close current and open next.
    1787/ E8F0:                ;* [<data>]</><=>     - Reopen current location.
    1788/ E8F0:                ;*     The contents of the current location is only
    1789/ E8F0:                ;*  changed if valid data is entered before each
    1790/ E8F0:                ;*  subcommand.
    1791/ E8F0:                ;* [<addr>]O - Compute relative offset from current
    1792/ E8F0:                ;*     location to <addr>.  The current location must
    1793/ E8F0:                ;*     be the address of the offset byte.
    1794/ E8F0:                ;**********
    1795/ E8F0:                ;*a = wskip();
    1796/ E8F0:                ;*if(a != cr)
    1797/ E8F0:                ;*     a = buffarg();
    1798/ E8F0:                ;*     if(a != cr) return(bad argument);
    1799/ E8F0:                ;*     if(countu1 != 0) ptrmem[] = shftreg;
    1800/ E8F0:

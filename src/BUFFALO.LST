    3047/ EFE4:
    3048/ EFE4:                ;*Mnemonic table for hc11 line assembler
    3049/ EFE4: =$0            NULL            EQU   $0              ;nothing
    3050/ EFE4: =$1            INH             EQU   $1              ;inherent
    3051/ EFE4: =$2            P2INH           EQU   $2              ;page 2 inherent
    3052/ EFE4: =$3            GEN             EQU   $3              ;general addressing
    3053/ EFE4: =$4            GRP2            EQU   $4              ;group 2
    3054/ EFE4: =$5            REL             EQU   $5              ;relative
    3055/ EFE4: =$6            IMM             EQU   $6              ;immediate
    3056/ EFE4: =$7            NIMM            EQU   $7              ;general except for immediate
    3057/ EFE4: =$8            LIMM            EQU   $8              ;2 byte immediate
    3058/ EFE4: =$9            XLIMM           EQU   $9              ;longimm for x
    3059/ EFE4: =$10           XNIMM           EQU   $10             ;no immediate for x
    3060/ EFE4: =$11           YLIMM           EQU   $11             ;longimm for y
    3061/ EFE4: =$12           YNIMM           EQU   $12             ;no immediate for y
    3062/ EFE4: =$13           BTB             EQU   $13             ;bit test and branch
    3063/ EFE4: =$14           SETCLR          EQU   $14             ;bit set or clear
    3064/ EFE4: =$15           CPD             EQU   $15             ;compare d
    3065/ EFE4: =$16           BTBD            EQU   $16             ;bit test and branch direct
    3066/ EFE4: =$17           SETCLRD         EQU   $17             ;bit set or clear direct
    3067/ EFE4:
    3068/ EFE4:                ;**********
    3069/ EFE4:                ;*   mnetabl - includes all '11 mnemonics, base opcodes,
    3070/ EFE4:                ;* and type of instruction.  The assembler search routine
    3071/ EFE4:                ;*depends on 4 characters for each mnemonic so that 3 char
    3072/ EFE4:                ;*mnemonics are extended with a space and 5 char mnemonics
    3073/ EFE4:                ;*are truncated.
    3074/ EFE4:                ;**********
    3075/ EFE4:
    3076/ EFE4: =$EFE4         MNETABL         EQU   *
    3077/ EFE4: 41 42 41 20                    FCC   'ABA '          ;  Mnemonic
    3078/ EFE8: 1B                             FCB   $1B             ;Base opcode

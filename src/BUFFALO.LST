     520/ E1FA: 08                             INX
     521/ E1FB: 81 53                          CMPA  #'S'            ;s is last register
     522/ E1FD: 26 F8                          BNE   RPRI1           ;jump if not done
     523/ E1FF: 38                             PULX
     524/ E200: 39                             RTS
     525/ E201:
     526/ E201:                ;*****************
     527/ E201:                ;*   HEXBIN(a) - Convert the ASCII character in a
     528/ E201:                ;* to binary and shift into shftreg.  Returns value
     529/ E201:                ;* in tmp1 incremented if a is not hex.
     530/ E201:                ;*****************
     531/ E201: 36             HEXBIN          PSHA
     532/ E202: 37                             PSHB
     533/ E203: 3C                             PSHX
     534/ E204: BD E1 A7                       JSR   UPCASE          ;convert to upper case
     535/ E207: 81 30                          CMPA  #'0'
     536/ E209: 2D 22                          BLT   HEXNOT          ;jump if a < $30
     537/ E20B: 81 39                          CMPA  #'9'
     538/ E20D: 2F 0A                          BLE   HEXNMB          ;jump if 0-9
     539/ E20F: 81 41                          CMPA  #'A'
     540/ E211: 2D 1A                          BLT   HEXNOT          ;jump if $39> a <$41
     541/ E213: 81 46                          CMPA  #'F'
     542/ E215: 2E 16                          BGT   HEXNOT          ;jump if a > $46
     543/ E217: 8B 09                          ADDA  #$9             ;convert $A-$F
     544/ E219: 84 0F          HEXNMB          ANDA  #$0F            ;convert to binary
     545/ E21B: CE 00 96                       LDX   #SHFTREG
     546/ E21E: C6 04                          LDAB  #4
     547/ E220: 68 01          HEXSHFT         ASL   1,X             ;2 byte shift through
     548/ E222: 69 00                          ROL   0,X             ;       carry bit
     549/ E224: 5A                             DECB
     550/ E225: 2E F9                          BGT   HEXSHFT         ;shift 4 times
     551/ E227: AA 01                          ORAA  1,X
     552/ E229: A7 01                          STAA  1,X
     553/ E22B: 20 03                          BRA   HEXRTS
     554/ E22D: 7C 00 C0       HEXNOT          INC   TMP1            ;indicate not hex
     555/ E230: 38             HEXRTS          PULX
     556/ E231: 33                             PULB
     557/ E232: 32                             PULA
     558/ E233: 39                             RTS
     559/ E234:
     560/ E234:                ;*****************
     561/ E234:                ;*  BUFFARG() - Build a hex argument from the
     562/ E234:                ;* contents of the input buffer. Characters are
     563/ E234:                ;* converted to binary and shifted into shftreg
     564/ E234:                ;* until a non-hex character is found.  On exit
     565/ E234:                ;* shftreg holds the last four digits read, count
     566/ E234:                ;* holds the number of digits read, ptrbuff points
     567/ E234:                ;* to the first non-hex character read, and A holds
     568/ E234:                ;* that first non-hex character.
     569/ E234:                ;*****************
     570/ E234:                ;*Initialize
     571/ E234:                ;*while((a=readbuff()) not hex)
     572/ E234:                ;*     hexbin(a);
     573/ E234:                ;*return();
     574/ E234:
     575/ E234: 7F 00 C0       BUFFARG         CLR   TMP1            ;not hex indicator
     576/ E237: 7F 00 A8                       CLR   COUNT           ;# or digits
     577/ E23A: 7F 00 96                       CLR   SHFTREG
     578/ E23D: 7F 00 97                       CLR   SHFTREG+1
     579/ E240: BD E2 FC                       JSR   WSKIP
     580/ E243: BD E2 E7       BUFFLP          JSR   READBUFF        ;read char
     581/ E246: BD E2 01                       JSR   HEXBIN
     582/ E249: 7D 00 C0                       TST   TMP1
     583/ E24C: 26 08                          BNE   BUFFRTS         ;jump if not hex
     584/ E24E: 7C 00 A8                       INC   COUNT
     585/ E251: BD E2 EE                       JSR   INCBUFF         ;move buffer pointer
     586/ E254: 20 ED                          BRA   BUFFLP
     587/ E256: 39             BUFFRTS         RTS
     588/ E257:
     589/ E257:                ;*****************
     590/ E257:                ;*  TERMARG() - Build a hex argument from the
     591/ E257:                ;* terminal.  Characters are converted to binary
     592/ E257:                ;* and shifted into shftreg until a non-hex character
     593/ E257:                ;* is found.  On exit shftreg holds the last four
     594/ E257:                ;* digits read, count holds the number of digits
     595/ E257:                ;* read, and A holds the first non-hex character.
     596/ E257:                ;*****************
     597/ E257:                ;*initialize
     598/ E257:                ;*while((a=inchar()) == hex)
     599/ E257:                ;*     if(a = cntlx or del)
     600/ E257:                ;*          abort;
     601/ E257:                ;*     else
     602/ E257:                ;*          hexbin(a); countu1++;
     603/ E257:                ;*return();
     604/ E257:
     605/ E257: 7F 00 A8       TERMARG         CLR   COUNT
     606/ E25A: 7F 00 96                       CLR   SHFTREG
     607/ E25D: 7F 00 97                       CLR   SHFTREG+1
     608/ E260: BD E5 31       TERM0           JSR   INCHAR
     609/ E263: 81 18                          CMPA  #CTLX
     610/ E265: 27 04                          BEQ   TERM1           ;jump if controlx
     611/ E267: 81 7F                          CMPA  #DEL
     612/ E269: 26 03                          BNE   TERM2           ;jump if not delete
     613/ E26B: 7E E0 C8       TERM1           JMP   MAIN            ;abort
     614/ E26E: 7F 00 C0       TERM2           CLR   TMP1            ;hex indicator
     615/ E271: BD E2 01                       JSR   HEXBIN
     616/ E274: 7D 00 C0                       TST   TMP1
     617/ E277: 26 05                          BNE   TERM3           ;jump if not hex
     618/ E279: 7C 00 A8                       INC   COUNT
     619/ E27C: 20 E2                          BRA   TERM0
     620/ E27E: 39             TERM3           RTS
     621/ E27F:
     622/ E27F:                ;*****************
     623/ E27F:                ;*   CHGBYT() - If shftreg is not empty, put
     624/ E27F:                ;* contents of shftreg at address in X.  If X
     625/ E27F:                ;* is an address in EEPROM then program it.
     626/ E27F:                ;*****************
     627/ E27F:                ;*if(count != 0)
     628/ E27F:                ;*   (x) = a;
     629/ E27F: 7D 00 A8       CHGBYT          TST   COUNT
     630/ E282: 27 05                          BEQ   CHGBYT4         ;quit if shftreg empty
     631/ E284: 96 97                          LDAA  SHFTREG+1       ;get data into a
     632/ E286: BD E2 8A                       JSR   WRITE
     633/ E289: 39             CHGBYT4         RTS
     634/ E28A:
     635/ E28A:
     636/ E28A:                ;*****************
     637/ E28A:                ;* WRITE() - This routine is used to write the
     638/ E28A:                ;*contents of A to the address of X.  If the
     639/ E28A:                ;*address is in EEPROM, it will be programmed
     640/ E28A:                ;*and if it is already programmed, it will be
     641/ E28A:                ;*byte erased first.
     642/ E28A:                ;******************
     643/ E28A:                ;*if(X == config) then
     644/ E28A:                ;*   byte erase config;
     645/ E28A:                ;*if(X is eeprom)then
     646/ E28A:                ;*   if(not erased) then erase;
     647/ E28A:                ;*   program (x) = A;
     648/ E28A:                ;*write (x) = A;
     649/ E28A:                ;*if((x) != A) error(rom);
     650/ E28A: =$E28A         WRITE           EQU   *
     651/ E28A: 8C 00 3F                       CPX   #CONFIG
     652/ E28D: 27 10                          BEQ   WRITE0          ;jump if config
     653/ E28F: 9C 98                          CPX   STREE           ;start of EE
     654/ E291: 25 12                          BLO   WRITE2          ;jump if not EE
     655/ E293: 9C 9A                          CPX   ENDEE           ;end of EE
     656/ E295: 22 0E                          BHI   WRITE2          ;jump if not EE
     657/ E297: 37             WRITEE          PSHB                  ;check if byte erased
     658/ E298: E6 00                          LDAB  0,X
     659/ E29A: C1 FF                          CMPB  #$FF
     660/ E29C: 33                             PULB
     661/ E29D: 27 03                          BEQ   WRITE1          ;jump if erased
     662/ E29F: BD E2 BF       WRITE0          JSR   EEBYTE          ;byte erase
     663/ E2A2: BD E2 B4       WRITE1          JSR   EEWRIT          ;byte program
     664/ E2A5: A7 00          WRITE2          STAA  0,X             ;write for non EE
     665/ E2A7: A1 00                          CMPA  0,X
     666/ E2A9: 27 08                          BEQ   WRITE3          ;jump if write ok
     667/ E2AB: 3C                             PSHX
     668/ E2AC: CE E6 8A                       LDX   #MSG6           ;"rom"
     669/ E2AF: BD E5 05                       JSR   OUTSTRG
     670/ E2B2: 38                             PULX
     671/ E2B3: 39             WRITE3          RTS
     672/ E2B4:
     673/ E2B4:
     674/ E2B4:                ;*****************
     675/ E2B4:                ;*   EEWRIT(), EEBYTE(), EEBULK() -
     676/ E2B4:                ;* These routines are used to program and eeprom
     677/ E2B4:                ;*locations.  eewrite programs the address in X with
     678/ E2B4:                ;*the value in A, eebyte does a byte address at X,
     679/ E2B4:                ;*and eebulk does a bulk of eeprom.  Whether eebulk
     680/ E2B4:                ;*erases the config or not depends on the address it
     681/ E2B4:                ;*receives in X.
     682/ E2B4:                ;****************
     683/ E2B4: =$E2B4         EEWRIT          EQU   *               ;program one byte at x
     684/ E2B4: 37                             PSHB
     685/ E2B5: C6 02                          LDAB  #$02
     686/ E2B7: D7 3B                          STAB  PPROG
     687/ E2B9: A7 00                          STAA  0,X
     688/ E2BB: C6 03                          LDAB  #$03
     689/ E2BD: 20 16                          BRA   EEPROG
     690/ E2BF:                ;***
     691/ E2BF: =$E2BF         EEBYTE          EQU   *               ;byte erase address x
     692/ E2BF: 37                             PSHB
     693/ E2C0: C6 16                          LDAB  #$16
     694/ E2C2: D7 3B                          STAB  PPROG
     695/ E2C4: C6 FF                          LDAB  #$FF
     696/ E2C6: E7 00                          STAB  0,X
     697/ E2C8: C6 17                          LDAB  #$17
     698/ E2CA: 20 09                          BRA   EEPROG
     699/ E2CC:                ;***
     700/ E2CC: =$E2CC         EEBULK          EQU   *               ;bulk erase eeprom
     701/ E2CC: 37                             PSHB
     702/ E2CD: C6 06                          LDAB  #$06
     703/ E2CF: D7 3B                          STAB  PPROG
     704/ E2D1: A7 00                          STAA  0,X             ;erase config or not ...
     705/ E2D3: C6 07                          LDAB  #$07            ;  ... depends on X addr
     706/ E2D5: 26 01          EEPROG          BNE   ACL1
     707/ E2D7: 5F                             CLRB                  ;fail safe
     708/ E2D8: D7 3B          ACL1            STAB  PPROG
     709/ E2DA: 33                             PULB
     710/ E2DB:                ;***
     711/ E2DB: =$E2DB         DLY10MS         EQU   *               ;delay 10ms at E = 2MHz
     712/ E2DB: 3C                             PSHX
     713/ E2DC: CE 0D 06                       LDX   #$0D06
     714/ E2DF: 09             DLYLP           DEX
     715/ E2E0: 26 FD                          BNE   DLYLP
     716/ E2E2: 38                             PULX
     717/ E2E3: 7F 00 3B                       CLR   PPROG
     718/ E2E6: 39                             RTS
     719/ E2E7:
     720/ E2E7:
     721/ E2E7:                ;*****************
     722/ E2E7:                ;*  READBUFF() -  Read the character in INBUFF
     723/ E2E7:                ;* pointed at by ptrbuff into A.  Returns ptrbuff
     724/ E2E7:                ;* unchanged.
     725/ E2E7:                ;*****************
     726/ E2E7: 3C             READBUFF        PSHX
     727/ E2E8: DE AE                          LDX   PTR0
     728/ E2EA: A6 00                          LDAA  0,X
     729/ E2EC: 38                             PULX
     730/ E2ED: 39                             RTS
     731/ E2EE:
     732/ E2EE:                ;*****************
     733/ E2EE:                ;*  INCBUFF(), DECBUFF() - Increment or decrement
     734/ E2EE:                ;* ptrbuff.
     735/ E2EE:                ;*****************
     736/ E2EE: 3C             INCBUFF         PSHX
     737/ E2EF: DE AE                          LDX   PTR0
     738/ E2F1: 08                             INX
     739/ E2F2: 20 04                          BRA   INCDEC
     740/ E2F4: 3C             DECBUFF         PSHX
     741/ E2F5: DE AE                          LDX   PTR0
     742/ E2F7: 09                             DEX
     743/ E2F8: DF AE          INCDEC          STX   PTR0
     744/ E2FA: 38                             PULX
     745/ E2FB: 39                             RTS
     746/ E2FC:
     747/ E2FC:                ;*****************
     748/ E2FC:                ;*  WSKIP() - Read from the INBUFF until a
     749/ E2FC:                ;* non whitespace (space, comma, tab) character
     750/ E2FC:                ;* is found.  Returns ptrbuff pointing to the
     751/ E2FC:                ;* first non-whitespace character and a holds
     752/ E2FC:                ;* that character.  WSKIP also compares a to
     753/ E2FC:                ;* $0D (CR) and cond codes indicating the
     754/ E2FC:                ;* results of that compare.
     755/ E2FC:                ;*****************
     756/ E2FC: BD E2 E7       WSKIP           JSR   READBUFF        ;read character
     757/ E2FF: BD E3 0C                       JSR   WCHEK
     758/ E302: 26 05                          BNE   WSKIP1          ;jump if not wspc
     759/ E304: BD E2 EE                       JSR   INCBUFF         ;move pointer
     760/ E307: 20 F3                          BRA   WSKIP           ;loop
     761/ E309: 81 0D          WSKIP1          CMPA  #$0D
     762/ E30B: 39                             RTS
     763/ E30C:
     764/ E30C:                ;*****************
     765/ E30C:                ;*  WCHEK(a) - Returns z=1 if a holds a
     766/ E30C:                ;* whitespace character, else z=0.
     767/ E30C:                ;*****************
     768/ E30C: 81 2C          WCHEK           CMPA  #$2C            ;comma
     769/ E30E: 27 06                          BEQ   WCHEK1
     770/ E310: 81 20                          CMPA  #$20            ;space
     771/ E312: 27 02                          BEQ   WCHEK1
     772/ E314: 81 09                          CMPA  #$09            ;tab
     773/ E316: 39             WCHEK1          RTS
     774/ E317:
     775/ E317:                ;*****************
     776/ E317:                ;*   DCHEK(a) - Returns Z=1 if a = whitespace
     777/ E317:                ;* or carriage return.  Else returns z=0.
     778/ E317:                ;*****************
     779/ E317: BD E3 0C       DCHEK           JSR   WCHEK
     780/ E31A: 27 02                          BEQ   DCHEK1          ;jump if whitespace
     781/ E31C: 81 0D                          CMPA  #$0D
     782/ E31E: 39             DCHEK1          RTS
     783/ E31F:
     784/ E31F:                ;*****************
     785/ E31F:                ;*  CHKABRT() - Checks for a control x or delete
     786/ E31F:                ;* from the terminal.  If found, the stack is
     787/ E31F:                ;* reset and the control is transferred to main.
     788/ E31F:                ;* Note that this is an abnormal termination.
     789/ E31F:                ;*   If the input from the terminal is a control W
     790/ E31F:                ;* then this routine keeps waiting until any other
     791/ E31F:                ;* character is read.
     792/ E31F:                ;*****************
     793/ E31F:                ;*a=input();
     794/ E31F:                ;*if(a=cntl w) wait until any other key;
     795/ E31F:                ;*if(a = cntl x or del) abort;
     796/ E31F:
     797/ E31F: BD E3 94       CHKABRT         JSR   INPUT
     798/ E322: 27 18                          BEQ   CHK4            ;jump if no input
     799/ E324: 81 17                          CMPA  #CTLW
     800/ E326: 26 05                          BNE   CHK2            ;jump in not cntlw
     801/ E328: BD E3 94       CHKABRT1        JSR   INPUT
     802/ E32B: 27 FB                          BEQ   CHKABRT1        ;jump if no input
     803/ E32D: 81 7F          CHK2            CMPA  #DEL
     804/ E32F: 27 08                          BEQ   CHK3            ;jump if delete
     805/ E331: 81 18                          CMPA  #CTLX
     806/ E333: 27 04                          BEQ   CHK3            ;jump if control x
     807/ E335: 81 01                          CMPA  #CTLA
     808/ E337: 26 03                          BNE   CHK4            ;jump not control a
     809/ E339: 7E E0 C8       CHK3            JMP   MAIN            ;abort
     810/ E33C: 39             CHK4            RTS                   ;return
     811/ E33D:
     812/ E33D:                ;***********************
     813/ E33D:                ;*  HOSTCO - connect sci to host for evb board.
     814/ E33D:                ;*  TARGCO - connect sci to target for evb board.
     815/ E33D:                ;***********************
     816/ E33D: 36             HOSTCO          PSHA
     817/ E33E: 86 01                          LDAA  #$01
     818/ E340: B7 40 00                       STAA  DFLOP           ;send 1 to d-flop
     819/ E343: 32                             PULA
     820/ E344: 39                             RTS
     821/ E345:
     822/ E345: 36             TARGCO          PSHA
     823/ E346: 86 00                          LDAA  #$00
     824/ E348: B7 40 00                       STAA  DFLOP           ;send 0 to d-flop
     825/ E34B: 32                             PULA
     826/ E34C: 39                             RTS
     827/ E34D:
     828/ E34D:                ;*
     829/ E34D:                ;**********
     830/ E34D:                ;*
     831/ E34D:                ;*     VECINIT - This routine checks for
     832/ E34D:                ;*        vectors in the RAM table.  All
     833/ E34D:                ;*        uninitialized vectors are programmed
     834/ E34D:                ;*        to JMP STOPIT
     835/ E34D:                ;*
     836/ E34D:                ;**********
     837/ E34D:                ;*
     838/ E34D: CE 00 C4       VECINIT         LDX   #JSCI           ;Point to First RAM Vector
     839/ E350: 18 CE E3 67                    LDY   #STOPIT         ;Pointer to STOPIT routine
     840/ E354: CC 7E 03                       LDD   #$7E03          ;A=JMP opcode; B=offset
     841/ E357: A1 00          VECLOOP         CMPA  0,X
     842/ E359: 27 05                          BEQ   VECNEXT         ;If vector already in
     843/ E35B: A7 00                          STAA  0,X             ;install JMP
     844/ E35D: 1A EF 01                       STY   1,X             ;to STOPIT routine
     845/ E360: 3A             VECNEXT         ABX                   ;Add 3 to point at next vector
     846/ E361: 8C 01 00                       CPX   #JCLM+3         ;Done?
     847/ E364: 26 F1                          BNE   VECLOOP         ;If not, continue loop
     848/ E366: 39                             RTS
     849/ E367:                ;*
     850/ E367: 86 50          STOPIT          LDAA  #$50            ;Stop-enable; IRQ, XIRQ-Off
     851/ E369: 06                             TAP
     852/ E36A: CF                             STOP                  ;You are lost!  Shut down
     853/ E36B: 7E E3 67                       JMP   STOPIT          ;In case continue by XIRQ
     854/ E36E:
     855/ E36E:                ;**********
     856/ E36E:                ;*
     857/ E36E:                ;*   I/O MODULE
     858/ E36E:                ;*     Communications with the outside world.
     859/ E36E:                ;* 3 I/O routines (INIT, INPUT, and OUTPUT) call
     860/ E36E:                ;* drivers specified by IODEV (0=SCI, 1=ACIA,
     861/ E36E:                ;* 2=DUARTA, 3=DUARTB).
     862/ E36E:                ;*
     863/ E36E:                ;**********
     864/ E36E:                ;*   INIT() - Initialize device specified by iodev.
     865/ E36E:                ;*********
     866/ E36E:                ;*
     867/ E36E: =$E36E         INIT            EQU   *
     868/ E36E: 36                             PSHA                  ;save registers
     869/ E36F: 3C                             PSHX
     870/ E370: 96 A5                          LDAA  IODEV
     871/ E372: 81 00                          CMPA  #$00
     872/ E374: 26 05                          BNE   INIT1           ;jump not sci
     873/ E376: BD E4 3D                       JSR   ONSCI           ;initialize sci
     874/ E379: 20 16                          BRA   INIT4
     875/ E37B: 81 01          INIT1           CMPA  #$01
     876/ E37D: 26 05                          BNE   INIT2           ;jump not acia
     877/ E37F: BD E4 75                       JSR   ONACIA          ;initialize acia
     878/ E382: 20 0D                          BRA   INIT4
     879/ E384: CE D0 00       INIT2           LDX   #PORTA
     880/ E387: 81 02                          CMPA  #$02
     881/ E389: 27 03                          BEQ   INIT3           ;jump duart a
     882/ E38B: CE D0 08                       LDX   #PORTB
     883/ E38E: BD E3 E7       INIT3           JSR   ONUART          ;initialize duart
     884/ E391: 38             INIT4           PULX                  ;restore registers
     885/ E392: 32                             PULA
     886/ E393: 39                             RTS
     887/ E394:
     888/ E394:                ;**********
     889/ E394:                ;*  INPUT() - Read device. Returns a=char or 0.
     890/ E394:                ;*    This routine also disarms the cop.
     891/ E394:                ;**********
     892/ E394: =$E394         INPUT           EQU   *
     893/ E394: 3C                             PSHX
     894/ E395: 86 55                          LDAA  #$55            ;reset cop
     895/ E397: 97 3A                          STAA  COPRST
     896/ E399: 86 AA                          LDAA  #$AA
     897/ E39B: 97 3A                          STAA  COPRST
     898/ E39D: 96 A5                          LDAA  IODEV
     899/ E39F: 26 05                          BNE   INPUT1          ;jump not sci
     900/ E3A1: BD E4 4A                       JSR   INSCI           ;read sci
     901/ E3A4: 20 16                          BRA   INPUT4
     902/ E3A6: 81 01          INPUT1          CMPA  #$01
     903/ E3A8: 26 05                          BNE   INPUT2          ;jump not acia
     904/ E3AA: BD E4 81                       JSR   INACIA          ;read acia
     905/ E3AD: 20 0D                          BRA   INPUT4
     906/ E3AF: CE D0 00       INPUT2          LDX   #PORTA
     907/ E3B2: 81 02                          CMPA  #$02
     908/ E3B4: 27 03                          BEQ   INPUT3          ;jump if duart a
     909/ E3B6: CE D0 08                       LDX   #PORTB
     910/ E3B9: BD E4 12       INPUT3          JSR   INUART          ;read uart
     911/ E3BC: 38             INPUT4          PULX
     912/ E3BD: 39                             RTS
     913/ E3BE:
     914/ E3BE:                ;**********
     915/ E3BE:                ;*   OUTPUT() - Output character in A.
     916/ E3BE:                ;* chrcnt indicates the current column on the
     917/ E3BE:                ;*output display.  It is incremented every time
     918/ E3BE:                ;*a character is outputted, and cleared whenever
     919/ E3BE:                ;*the subroutine outcrlf is called.
     920/ E3BE:                ;**********
     921/ E3BE:
     922/ E3BE: =$E3BE         OUTPUT          EQU   *
     923/ E3BE: 36                             PSHA                  ;save registers
     924/ E3BF: 37                             PSHB
     925/ E3C0: 3C                             PSHX
     926/ E3C1: D6 A5                          LDAB  IODEV
     927/ E3C3: 26 05                          BNE   OUTPUT1         ;jump not sci
     928/ E3C5: BD E4 55                       JSR   OUTSCI          ;write sci
     929/ E3C8: 20 16                          BRA   OUTPUT4
     930/ E3CA: C1 01          OUTPUT1         CMPB  #$01
     931/ E3CC: 26 05                          BNE   OUTPUT2         ;jump not acia
     932/ E3CE: BD E4 9B                       JSR   OUTACIA         ;write acia
     933/ E3D1: 20 0D                          BRA   OUTPUT4
     934/ E3D3: CE D0 00       OUTPUT2         LDX   #PORTA
     935/ E3D6: C1 02                          CMPB  #$02
     936/ E3D8: 27 03                          BEQ   OUTPUT3         ;jump if duart a
     937/ E3DA: CE D0 08                       LDX   #PORTB
     938/ E3DD: BD E4 1D       OUTPUT3         JSR   OUTUART         ;write uart
     939/ E3E0: 38             OUTPUT4         PULX
     940/ E3E1: 33                             PULB
     941/ E3E2: 32                             PULA
     942/ E3E3: 7C 00 A9                       INC   CHRCNT          ;increment column count
     943/ E3E6: 39                             RTS
     944/ E3E7:
     945/ E3E7:                ;**********
     946/ E3E7:                ;*   ONUART(port) - Initialize a duart port.
     947/ E3E7:                ;* Sets duart to internal clock, divide by 16,
     948/ E3E7:                ;* 8 data + 1 stop bits.
     949/ E3E7:                ;**********
     950/ E3E7:
     951/ E3E7: 86 22          ONUART          LDAA  #$22
     952/ E3E9: A7 02                          STAA  2,X             ;reset receiver
     953/ E3EB: 86 38                          LDAA  #$38
     954/ E3ED: A7 02                          STAA  2,X             ;reset transmitter
     955/ E3EF: 86 40                          LDAA  #$40
     956/ E3F1: A7 02                          STAA  2,X             ;reset error status
     957/ E3F3: 86 10                          LDAA  #$10
     958/ E3F5: A7 02                          STAA  2,X             ;reset pointer
     959/ E3F7: 86 00                          LDAA  #$00
     960/ E3F9: B7 D0 04                       STAA  DUART+4         ;clock source
     961/ E3FC: 86 00                          LDAA  #$00
     962/ E3FE: B7 D0 05                       STAA  DUART+5         ;interrupt mask
     963/ E401: 86 13                          LDAA  #$13
     964/ E403: A7 00                          STAA  0,X             ;8 data, no parity
     965/ E405: 86 07                          LDAA  #$07
     966/ E407: A7 00                          STAA  0,X             ;1 stop bits
     967/ E409: 86 BB                          LDAA  #$BB            ;baud rate (9600)
     968/ E40B: A7 01                          STAA  1,X             ;tx and rcv baud rate
     969/ E40D: 86 05                          LDAA  #$05
     970/ E40F: A7 02                          STAA  2,X             ;enable tx and rcv
     971/ E411: 39                             RTS
     972/ E412:
     973/ E412:                ;**********
     974/ E412:                ;*   INUART(port) - Check duart for any input.
     975/ E412:                ;**********
     976/ E412: A6 01          INUART          LDAA  1,X             ;read status
     977/ E414: 84 01                          ANDA  #$01            ;check rxrdy
     978/ E416: 27 04                          BEQ   INUART1         ;jump if no data
     979/ E418: A6 03                          LDAA  3,X             ;read data
     980/ E41A: 84 7F                          ANDA  #$7F            ;mask parity
     981/ E41C: 39             INUART1         RTS
     982/ E41D:
     983/ E41D:                ;**********
     984/ E41D:                ;*   OUTUART(port) - Output the character in a.
     985/ E41D:                ;*        if autolf=1, transmits cr or lf as crlf.
     986/ E41D:                ;**********
     987/ E41D: 7D 00 A4       OUTUART         TST   AUTOLF
     988/ E420: 27 10                          BEQ   OUTUART2        ;jump if no autolf
     989/ E422: 8D 0E                          BSR   OUTUART2
     990/ E424: 81 0D                          CMPA  #$0D
     991/ E426: 26 04                          BNE   OUTUART1
     992/ E428: 86 0A                          LDAA  #$0A            ;if cr, output lf
     993/ E42A: 20 06                          BRA   OUTUART2
     994/ E42C: 81 0A          OUTUART1        CMPA  #$0A
     995/ E42E: 26 0C                          BNE   OUTUART3
     996/ E430: 86 0D                          LDAA  #$0D            ;if lf, output cr
     997/ E432: E6 01          OUTUART2        LDAB  1,X             ;check status
     998/ E434: C4 04                          ANDB  #$4
     999/ E436: 27 FA                          BEQ   OUTUART2        ;loop until tdre=1
    1000/ E438: 84 7F                          ANDA  #$7F            ;mask parity
    1001/ E43A: A7 03                          STAA  3,X             ;send character
    1002/ E43C: 39             OUTUART3        RTS
    1003/ E43D:
    1004/ E43D:                ;**********
    1005/ E43D:                ;*   ONSCI() - Initialize the SCI for 9600
    1006/ E43D:                ;*                 baud at 8 MHz Extal.
    1007/ E43D:                ;**********
    1008/ E43D:                ;ONSCI    LDAA #$30
    1009/ E43D: 86 00          ONSCI           LDAA  #$00            ; E/16
    1010/ E43F: 97 2B                          STAA  BAUD            ;baud register
    1011/ E441: 86 00                          LDAA  #$00
    1012/ E443: 97 2C                          STAA  SCCR1
    1013/ E445: 86 0C                          LDAA  #$0C
    1014/ E447: 97 2D                          STAA  SCCR2           ;enable
    1015/ E449: 39                             RTS
    1016/ E44A:
    1017/ E44A:                ;**********
    1018/ E44A:                ;*   INSCI() - Read from SCI.  Return a=char or 0.
    1019/ E44A:                ;**********
    1020/ E44A: 96 2E          INSCI           LDAA  SCSR            ;read status reg
    1021/ E44C: 84 20                          ANDA  #$20            ;check rdrf
    1022/ E44E: 27 04                          BEQ   INSCI1          ;jump if no data
    1023/ E450: 96 2F                          LDAA  SCDAT           ;read data
    1024/ E452: 84 7F                          ANDA  #$7F            ;mask parity
    1025/ E454: 39             INSCI1          RTS
    1026/ E455:
    1027/ E455:                ;**********
    1028/ E455:                ;*  OUTSCI() - Output A to sci. IF autolf = 1,
    1029/ E455:                ;*               cr and lf sent as crlf.
    1030/ E455:                ;**********
    1031/ E455: 7D 00 A4       OUTSCI          TST   AUTOLF
    1032/ E458: 27 10                          BEQ   OUTSCI2         ;jump if autolf=0
    1033/ E45A: 8D 0E                          BSR   OUTSCI2
    1034/ E45C: 81 0D                          CMPA  #$0D
    1035/ E45E: 26 04                          BNE   OUTSCI1
    1036/ E460: 86 0A                          LDAA  #$0A            ;if cr, send lf
    1037/ E462: 20 06                          BRA   OUTSCI2
    1038/ E464: 81 0A          OUTSCI1         CMPA  #$0A
    1039/ E466: 26 0C                          BNE   OUTSCI3
    1040/ E468: 86 0D                          LDAA  #$0D            ;if lf, send cr
    1041/ E46A: D6 2E          OUTSCI2         LDAB  SCSR            ;read status
    1042/ E46C: C5 80                          BITB  #$80
    1043/ E46E: 27 FA                          BEQ   OUTSCI2         ;loop until tdre=1
    1044/ E470: 84 7F                          ANDA  #$7F            ;mask parity
    1045/ E472: 97 2F                          STAA  SCDAT           ;send character
    1046/ E474: 39             OUTSCI3         RTS
    1047/ E475:
    1048/ E475:                ;**********
    1049/ E475:                ;*   ONACIA - Initialize the ACIA for
    1050/ E475:                ;* 8 data bits, 1 stop bit, divide by 64 clock.
    1051/ E475:                ;**********
    1052/ E475: CE DF 00       ONACIA          LDX   #ACIA
    1053/ E478: 86 03                          LDAA  #$03
    1054/ E47A: A7 00                          STAA  0,X             ;master reset
    1055/ E47C: 86 16                          LDAA  #$16
    1056/ E47E: A7 00                          STAA  0,X             ;setup
    1057/ E480: 39                             RTS
    1058/ E481:
    1059/ E481:                ;**********
    1060/ E481:                ;*   INACIA - Read from the ACIA, Return a=char or 0.
    1061/ E481:                ;* Tmp3 is used to flag overrun or framing error.
    1062/ E481:                ;**********
    1063/ E481: CE DF 00       INACIA          LDX   #ACIA
    1064/ E484: A6 00                          LDAA  0,X             ;read status register
    1065/ E486: 36                             PSHA
    1066/ E487: 84 30                          ANDA  #$30            ;check ov, fe
    1067/ E489: 32                             PULA
    1068/ E48A: 27 06                          BEQ   INACIA1         ;jump - no error
    1069/ E48C: 86 01                          LDAA  #$01
    1070/ E48E: 97 C2                          STAA  TMP3            ;flag reciever error
    1071/ E490: 20 04                          BRA   INACIA2         ;read data to clear status
    1072/ E492: 84 01          INACIA1         ANDA  #$01            ;check rdrf
    1073/ E494: 27 04                          BEQ   INACIA3         ;jump if no data
    1074/ E496: A6 01          INACIA2         LDAA  1,X             ;read data
    1075/ E498: 84 7F                          ANDA  #$7F            ;mask parity
    1076/ E49A: 39             INACIA3         RTS
    1077/ E49B:
    1078/ E49B:                ;**********
    1079/ E49B:                ;*  OUTACIA - Output A to acia. IF autolf = 1,
    1080/ E49B:                ;*               cr or lf sent as crlf.
    1081/ E49B:                ;**********
    1082/ E49B: 8D 18          OUTACIA         BSR   OUTACIA3        ;output char
    1083/ E49D: 7D 00 A4                       TST   AUTOLF
    1084/ E4A0: 27 12                          BEQ   OUTACIA2        ;jump no autolf
    1085/ E4A2: 81 0D                          CMPA  #$0D
    1086/ E4A4: 26 06                          BNE   OUTACIA1
    1087/ E4A6: 86 0A                          LDAA  #$0A
    1088/ E4A8: 8D 0B                          BSR   OUTACIA3        ;if cr, output lf
    1089/ E4AA: 20 08                          BRA   OUTACIA2
    1090/ E4AC: 81 0A          OUTACIA1        CMPA  #$0A
    1091/ E4AE: 26 04                          BNE   OUTACIA2
    1092/ E4B0: 86 0D                          LDAA  #$0D
    1093/ E4B2: 8D 01                          BSR   OUTACIA3        ;if lf, output cr
    1094/ E4B4: 39             OUTACIA2        RTS
    1095/ E4B5:
    1096/ E4B5: CE DF 00       OUTACIA3        LDX   #ACIA
    1097/ E4B8: E6 00                          LDAB  0,X
    1098/ E4BA: C5 02                          BITB  #$2
    1099/ E4BC: 27 F7                          BEQ   OUTACIA3        ;loop until tdre
    1100/ E4BE: 84 7F                          ANDA  #$7F            ;mask parity
    1101/ E4C0: A7 01                          STAA  1,X             ;output
    1102/ E4C2: 39                             RTS
    1103/ E4C3:                ;*
    1104/ E4C3:                ;*        Space for modifying OUTACIA routine
    1105/ E4C3:                ;*
    1106/ E4C3: FF FF FF FF FF                 FDB   $FFFF,$FFFF,$FFFF,$FFFF
    1106/ E4C8: FF FF FF
    1107/ E4CB:                ;*******************************
    1108/ E4CB:                ;*** I/O UTILITY SUBROUTINES ***
    1109/ E4CB:                ;***These subroutines perform the neccesary
    1110/ E4CB:                ;* data I/O operations.
    1111/ E4CB:                ;* OUTLHLF-Convert left 4 bits of A from binary
    1112/ E4CB:                ;*            to ASCII and output.
    1113/ E4CB:                ;* OUTRHLF-Convert right 4 bits of A from binary
    1114/ E4CB:                ;*            to ASCII and output.
    1115/ E4CB:                ;* OUT1BYT-Convert byte addresed by X from binary
    1116/ E4CB:                ;*           to ASCII and output.
    1117/ E4CB:                ;* OUT1BSP-Convert byte addressed by X from binary
    1118/ E4CB:                ;*           to ASCII and output followed by a space.
    1119/ E4CB:                ;* OUT2BSP-Convert 2 bytes addressed by X from binary
    1120/ E4CB:                ;*            to ASCII and  output followed by a space.
    1121/ E4CB:                ;* OUTSPAC-Output a space.
    1122/ E4CB:                ;*
    1123/ E4CB:                ;* OUTCRLF-Output a line feed and carriage return.
    1124/ E4CB:                ;*
    1125/ E4CB:                ;* OUTSTRG-Output the string of ASCII bytes addressed
    1126/ E4CB:                ;*            by X until $04.
    1127/ E4CB:                ;* OUTA-Output the ASCII character in A.
    1128/ E4CB:                ;*
    1129/ E4CB:                ;* TABTO-Output spaces until column 20 is reached.
    1130/ E4CB:                ;*
    1131/ E4CB:                ;* INCHAR-Input to A and echo one character.  Loops
    1132/ E4CB:                ;*            until character read.
    1133/ E4CB:                ;*        *******************
    1134/ E4CB:
    1135/ E4CB:                ;**********
    1136/ E4CB:                ;*  OUTRHLF(), OUTLHLF(), OUTA()
    1137/ E4CB:                ;*Convert A from binary to ASCII and output.
    1138/ E4CB:                ;*Contents of A are destroyed..
    1139/ E4CB:                ;**********
    1140/ E4CB: 44             OUTLHLF         LSRA                  ; shift data to right
    1141/ E4CC: 44                             LSRA
    1142/ E4CD: 44                             LSRA
    1143/ E4CE: 44                             LSRA
    1144/ E4CF: 84 0F          OUTRHLF         ANDA  #$0F            ;mask top half
    1145/ E4D1: 8B 30                          ADDA  #$30            ;convert to ascii
    1146/ E4D3: 81 39                          CMPA  #$39
    1147/ E4D5: 2F 02                          BLE   OUTA            ;jump if 0-9
    1148/ E4D7: 8B 07                          ADDA  #$07            ;convert to hex A-F
    1149/ E4D9: BD E3 BE       OUTA            JSR   OUTPUT          ;output character
    1150/ E4DC: 39                             RTS
    1151/ E4DD:
    1152/ E4DD:                ;**********
    1153/ E4DD:                ;*  OUT1BYT(x) - Convert the byte at X to two
    1154/ E4DD:                ;* ASCII characters and output. Return X pointing
    1155/ E4DD:                ;* to next byte.
    1156/ E4DD:                ;**********
    1157/ E4DD: 36             OUT1BYT         PSHA
    1158/ E4DE: A6 00                          LDAA  0,X             ;get data in a
    1159/ E4E0: 36                             PSHA                  ;save copy
    1160/ E4E1: 8D E8                          BSR   OUTLHLF         ;output left half
    1161/ E4E3: 32                             PULA                  ;retrieve copy
    1162/ E4E4: 8D E9                          BSR   OUTRHLF         ;output right half
    1163/ E4E6: 32                             PULA
    1164/ E4E7: 08                             INX
    1165/ E4E8: 39                             RTS
    1166/ E4E9:
    1167/ E4E9:                ;**********
    1168/ E4E9:                ;*  OUT1BSP(x), OUT2BSP(x) - Output 1 or 2 bytes
    1169/ E4E9:                ;* at x followed by a space.  Returns x pointing to
    1170/ E4E9:                ;* next byte.
    1171/ E4E9:                ;**********
    1172/ E4E9: BD E4 DD       OUT2BSP         JSR   OUT1BYT         ;do first byte
    1173/ E4EC: BD E4 DD       OUT1BSP         JSR   OUT1BYT         ;do next byte
    1174/ E4EF: 86 20          OUTSPAC         LDAA  #$20            ;output a space
    1175/ E4F1: BD E3 BE                       JSR   OUTPUT
    1176/ E4F4: 39                             RTS
    1177/ E4F5:
    1178/ E4F5:                ;**********
    1179/ E4F5:                ;*  OUTCRLF() - Output a Carriage return and
    1180/ E4F5:                ;* a line feed.  Returns a = cr.
    1181/ E4F5:                ;**********
    1182/ E4F5: 86 0D          OUTCRLF         LDAA  #$0D            ;cr
    1183/ E4F7: BD E3 BE                       JSR   OUTPUT          ;output a
    1184/ E4FA: 86 00                          LDAA  #$00
    1185/ E4FC: BD E3 BE                       JSR   OUTPUT          ;output padding
    1186/ E4FF: 86 0D                          LDAA  #$0D
    1187/ E501: 7F 00 A9                       CLR   CHRCNT          ;zero the column counter
    1188/ E504: 39                             RTS
    1189/ E505:
    1190/ E505:                ;**********
    1191/ E505:                ;*  OUTSTRG(x) - Output string of ASCII bytes
    1192/ E505:                ;* starting at x until end of text ($04).  Can
    1193/ E505:                ;* be paused by control w (any char restarts).
    1194/ E505:                ;**********
    1195/ E505: BD E4 F5       OUTSTRG         JSR   OUTCRLF
    1196/ E508: 36             OUTSTRG0        PSHA
    1197/ E509: A6 00          OUTSTRG1        LDAA  0,X             ;read char into a
    1198/ E50B: 81 04                          CMPA  #EOT
    1199/ E50D: 27 14                          BEQ   OUTSTRG3        ;jump if eot
    1200/ E50F: BD E3 BE                       JSR   OUTPUT          ;output character
    1201/ E512: 08                             INX
    1202/ E513: BD E3 94                       JSR   INPUT
    1203/ E516: 27 F1                          BEQ   OUTSTRG1        ;jump if no input
    1204/ E518: 81 17                          CMPA  #CTLW
    1205/ E51A: 26 ED                          BNE   OUTSTRG1        ;jump if not cntlw
    1206/ E51C: BD E3 94       OUTSTRG2        JSR   INPUT
    1207/ E51F: 27 FB                          BEQ   OUTSTRG2        ;jump if any input
    1208/ E521: 20 E6                          BRA   OUTSTRG1
    1209/ E523: 32             OUTSTRG3        PULA
    1210/ E524: 39                             RTS

    4864/ FE03: 96 96                          LDAA  SHFTREG
    4865/ FE05: A7 00                          STAA  0,X             ;put in top byte
    4866/ FE07: 08                             INX
    4867/ FE08: 96 97          REG7            LDAA  SHFTREG+1
    4868/ FE0A: A7 00                          STAA  0,X             ;put in bottom byte
    4869/ FE0C: 38             REG8            PULX
    4870/ FE0D: 32                             PULA
    4871/ FE0E: E6 00                          LDAB  0,X             ;CHECK FOR REGISTER S
    4872/ FE10: C1 53                          CMPB  #'S'
    4873/ FE12: 27 05                          BEQ   REG9            ;jump if "s"
    4874/ FE14: 08                             INX                   ;point to next register
    4875/ FE15: 81 0D                          CMPA  #$D
    4876/ FE17: 26 BD                          BNE   REG5            ;jump if not cr
    4877/ FE19: 39             REG9            RTS
    4878/ FE1A:
    4879/ FE1A:
    4880/ FE1A:                ;* Equates
    4881/ FE1A: =$8            JPORTD          EQU   $08
    4882/ FE1A: =$9            JDDRD           EQU   $09
    4883/ FE1A: =$2B           JBAUD           EQU   $2B
    4884/ FE1A: =$2C           JSCCR1          EQU   $2C
    4885/ FE1A: =$2D           JSCCR2          EQU   $2D
    4886/ FE1A: =$2E           JSCSR           EQU   $2E
    4887/ FE1A: =$2F           JSCDAT          EQU   $2F
    4888/ FE1A:                ;*
    4889/ FE1A:
    4890/ FE1A:                ;************
    4891/ FE1A:                ;*  xboot [<addr1> [<addr2>]] - Use SCI to talk to an 'hc11 in
    4892/ FE1A:                ;* boot mode.  Downloads bytes from addr1 thru addr2.
    4893/ FE1A:                ;* Default addr1 = $C000 and addr2 = $C0ff.
    4894/ FE1A:                ;*
    4895/ FE1A:                ;* IMPORTANT:
    4896/ FE1A:                ;* if talking to an 'A8 or 'A2: use either default addresses or ONLY
    4897/ FE1A:                ;*    addr1 - this sends 256 bytes
    4898/ FE1A:                ;* if talking to an 'E9: include BOTH addr1 and addr2 for variable
    4899/ FE1A:                ;*    length
    4900/ FE1A:                ;************
    4901/ FE1A:
    4902/ FE1A:                ;*Get arguments
    4903/ FE1A:                ;*If no args, default $C000
    4904/ FE1A: BD E2 FC       BOOT            JSR   WSKIP
    4905/ FE1D: 26 0B                          BNE   BOT1            ;jump if arguments
    4906/ FE1F: CE C0 FF                       LDX   #$C0FF          ;addr2 default
    4907/ FE22: DF B8                          STX   PTR5
    4908/ FE24: 18 CE C0 00                    LDY   #$C000          ;addr1 default
    4909/ FE28: 20 36                          BRA   BOT2            ;go - use default address
    4910/ FE2A:
    4911/ FE2A:                ;*Else get arguments
    4912/ FE2A: BD E2 34       BOT1            JSR   BUFFARG
    4913/ FE2D: 7D 00 A8                       TST   COUNT
    4914/ FE30: 27 27                          BEQ   BOTERR          ;jump if no address
    4915/ FE32: 18 DE 96                       LDY   SHFTREG         ;start address (addr1)
    4916/ FE35: BD E2 FC                       JSR   WSKIP
    4917/ FE38: 26 0C                          BNE   BOT1A           ;go get addr2
    4918/ FE3A: 18 DF B8                       STY   PTR5            ;default addr2...
    4919/ FE3D: DC B8                          LDD   PTR5            ;...by taking addr1...
    4920/ FE3F: C3 00 FF                       ADDD  #$FF            ;...and adding 255 to it...
    4921/ FE42: DD B8                          STD   PTR5            ;...for a total download of 256
    4922/ FE44: 20 1A                          BRA   BOT2            ;continue
    4923/ FE46:                ;*
    4924/ FE46: BD E2 34       BOT1A           JSR   BUFFARG
    4925/ FE49: 7D 00 A8                       TST   COUNT
    4926/ FE4C: 27 0B                          BEQ   BOTERR          ;jump if no address
    4927/ FE4E: DE 96                          LDX   SHFTREG         ;end address (addr2)
    4928/ FE50: DF B8                          STX   PTR5
    4929/ FE52: BD E2 FC                       JSR   WSKIP
    4930/ FE55: 26 02                          BNE   BOTERR          ;go use addr1 and addr2
    4931/ FE57: 20 07                          BRA   BOT2
    4932/ FE59:
    4933/ FE59:                ;*
    4934/ FE59: CE E6 98       BOTERR          LDX   #MSG9           ;"bad argument"
    4935/ FE5C: BD E5 05                       JSR   OUTSTRG
    4936/ FE5F: 39                             RTS
    4937/ FE60:
    4938/ FE60:                ;*Boot routine
    4939/ FE60: C6 FF          BOT2            LDAB  #$FF            ;control character ($ff -> download)
    4940/ FE62: BD FE 78                       JSR   BTSUB           ;set up SCI and send control char
    4941/ FE65:                ;*                        initializes X as register pointer
    4942/ FE65:                ;*Download block
    4943/ FE65: 18 A6 00       BLOP            LDAA  0,Y
    4944/ FE68: A7 2F                          STAA  JSCDAT,X        ;write to transmitter
    4945/ FE6A: 1F 2E 50 FC                    BRCLR JSCSR,X,#80,*   ;wait for TDRE
    4946/ FE6E: 18 9C B8                       CPY   PTR5            ;if last...
    4947/ FE71: 27 04                          BEQ   BTDONE          ;    ...quit
    4948/ FE73: 18 08                          INY                   ;else...
    4949/ FE75: 20 EE                          BRA   BLOP            ;    ...send next
    4950/ FE77: 39             BTDONE          RTS
    4951/ FE78:
    4952/ FE78:                ;************************************************
    4953/ FE78:                ;*Subroutine
    4954/ FE78:                ;*  btsub   - sets up SCI and outputs control character
    4955/ FE78:                ;* On entry, B = control character
    4956/ FE78:                ;* On exit,  X = $1000
    4957/ FE78:                ;*           A = $0C
    4958/ FE78:                ;***************************
    4959/ FE78:
    4960/ FE78: =$FE78         BTSUB           EQU   *
    4961/ FE78: CE 10 00                       LDX   #$1000          ;to use indexed addressing
    4962/ FE7B: 86 02                          LDAA  #$02
    4963/ FE7D: A7 08                          STAA  JPORTD,X        ;drive transmitter line
    4964/ FE7F: A7 09                          STAA  JDDRD,X         ;  high
    4965/ FE81: 6F 2D                          CLR   JSCCR2,X        ;turn off XMTR and RCVR
    4966/ FE83: 86 22                          LDAA  #$22            ;BAUD = /16
    4967/ FE85: A7 2B                          STAA  JBAUD,X
    4968/ FE87: 86 0C                          LDAA  #$0C            ;TURN ON XMTR & RCVR
    4969/ FE89: A7 2D                          STAA  JSCCR2,X
    4970/ FE8B: E7 2F                          STAB  JSCDAT,X
    4971/ FE8D: 1F 2E 50 FC                    BRCLR JSCSR,X,#80,*   ;wait for TDRE
    4972/ FE91: 39                             RTS
    4973/ FE92:
    4974/ FE92:
    4975/ FE92:                ;***********
    4976/ FE92:                ;* TILDE - This command is put into the combuff by the
    4977/ FE92:                ;* load command so that extraneous carriage returns after
    4978/ FE92:                ;* the load will not hang up.
    4979/ FE92: 39             TILDE           RTS
    4980/ FE93:
    4981/ FE93:                ;******************
    4982/ FE93:                ;*
    4983/ FE93:                ;*       EVBTEST - This routine makes it a little easier
    4984/ FE93:                ;*       on us to test this board.
    4985/ FE93:                ;*
    4986/ FE93:                ;******************
    4987/ FE93:
    4988/ FE93: 86 FF          EVBTEST         LDAA  #$FF
    4989/ FE95: B7 10 00                       STAA  $1000           ;Write ones to port A
    4990/ FE98: 7F 00 A4                       CLR   AUTOLF          ;Turn off auto lf
    4991/ FE9B: BD E3 3D                       JSR   HOSTCO          ;Connect host
    4992/ FE9E: BD FC 27                       JSR   HOSTINIT        ;Initialize host
    4993/ FEA1: 86 7F                          LDAA  #$7f
    4994/ FEA3: BD FC 3F                       JSR   HOSTOUT         ;Send Delete to Altos
    4995/ FEA6: 86 0D                          LDAA  #$0d
    4996/ FEA8: BD FC 3F                       JSR   HOSTOUT         ;Send <CR>
    4997/ FEAB: 7C 00 A4                       INC   AUTOLF          ;Turn on Auto LF
    4998/ FEAE: CE 00 70                       LDX   #INBUFF+5       ;Point at Load message
    4999/ FEB1: DF AE                          STX   PTR0            ;Set pointer for load command
    5000/ FEB3: 18 CE FE D1                    LDY   #MSGEVB         ;Point at cat line
    5001/ FEB7: 18 A6 00       LOOP            LDAA  0,Y             ;Loop to xfer command line
    5002/ FEBA: 81 04                          CMPA  #04             ;Into buffalo line buffer
    5003/ FEBC: 27 07                          BEQ   DONE            ;Quit on $04
    5004/ FEBE: A7 00                          STAA  0,X
    5005/ FEC0: 08                             INX                   ;next character
    5006/ FEC1: 18 08                          INY
    5007/ FEC3: 20 F2                          BRA   LOOP
    5008/ FEC5: 7F 00 C1       DONE            CLR   TMP2            ;Set load vs. verify
    5009/ FEC8: BD FC 80                       JSR   LOAD3           ;Jmp into middle of load
    5010/ FECB: 8E 00 5F                       LDS   #STACK          ;Reset Stack
    5011/ FECE: 7E C0 B3                       JMP   $C0B3           ;Jump to Downloaded code
    5012/ FED1:
    5013/ FED1: 63 61 74 20 65 MSGEVB          FCC   "cat evbtest.out"
    5013/ FED6: 76 62 74 65 73
    5013/ FEDB: 74 2E 6F 75 74
    5014/ FEE0: 0D                             FCB   $0D
    5015/ FEE1: 04                             FCB   $04
    5016/ FEE2:
    5017/ FEE2:
    5018/ FEE2:
    5019/ FEE2:                ;*** Jump table ***
    5020/ FF7C:                                ORG   ROMBS+$1F7C
    5021/ FF7C: 7E E0 C8       _WARMST         JMP   MAIN            ;warm start
    5022/ FF7F: 7E E1 B2       _BPCLR          JMP   BPCLR           ;clear breakpoint table
    5023/ FF82: 7E E1 F3       _RPRINT         JMP   RPRINT          ;display user registers
    5024/ FF85: 7E E2 01       _HEXBIN         JMP   HEXBIN          ;convert ascii hex char to binary
    5025/ FF88: 7E E2 34       _BUFFAR         JMP   BUFFARG         ;build hex argument from buffer
    5026/ FF8B: 7E E2 57       _TERMAR         JMP   TERMARG         ;read hex argument from terminal
    5027/ FF8E: 7E E2 7F       _CHGBYT         JMP   CHGBYT          ;modify memory at address in x
    5028/ FF91: 7E E2 E7       _READBU         JMP   READBUFF        ;read character from buffer
    5029/ FF94: 7E E2 EE       _INCBUF         JMP   INCBUFF         ;increment buffer pointer
    5030/ FF97: 7E E2 F4       _DECBUF         JMP   DECBUFF         ;decrement buffer pointer
    5031/ FF9A: 7E E2 FC       _WSKIP          JMP   WSKIP           ;find non-whitespace char in buffer
    5032/ FF9D: 7E E3 1F       _CHKABR         JMP   CHKABRT         ;check for abort from terminal
    5033/ FFA0:
    5034/ FFA0:                                ORG   ROMBS+$1FA0
    5035/ FFA0: 7E E1 A7       _UPCASE         JMP   UPCASE          ;convert to upper case
    5036/ FFA3: 7E E3 0C       _WCHEK          JMP   WCHEK           ;check for white space
    5037/ FFA6: 7E E3 17       _DCHEK          JMP   DCHEK           ;check for delimeter
    5038/ FFA9: 7E E3 6E       _INIT           JMP   INIT            ;initialize i/o device
    5039/ FFAC: 7E E3 94       _INPUT          JMP   INPUT           ;low level input routine
    5040/ FFAF: 7E E3 BE       _OUTPUT         JMP   OUTPUT          ;low level output routine
    5041/ FFB2: 7E E4 CB       _OUTLHL         JMP   OUTLHLF         ;display top 4 bits as hex digit
    5042/ FFB5: 7E E4 CF       _OUTRHL         JMP   OUTRHLF         ;display bottom 4 bits as hex digit
    5043/ FFB8: 7E E4 D9       _OUTA           JMP   OUTA            ;output ascii character in A
    5044/ FFBB: 7E E4 DD       _OUT1BY         JMP   OUT1BYT         ;display the hex value of byte at X
    5045/ FFBE: 7E E4 EC       _OUT1BS         JMP   OUT1BSP         ;out1byt followed by space
    5046/ FFC1: 7E E4 E9       _OUT2BS         JMP   OUT2BSP         ;display 2 hex bytes at x and a space
    5047/ FFC4: 7E E4 F5       _OUTCRL         JMP   OUTCRLF         ;carriage return, line feed to terminal
    5048/ FFC7: 7E E5 05       _OUTSTR         JMP   OUTSTRG         ;display string at X (term with $04)
    5049/ FFCA: 7E E5 08       _OUTST0         JMP   OUTSTRG0        ;outstrg with no initial carr ret
    5050/ FFCD: 7E E5 31       _INCHAR         JMP   INCHAR          ;wait for and input a char from term
    5051/ FFD0: 7E E3 4D       _VECINT         JMP   VECINIT         ;initialize RAM vector table
    5052/ FFD3:
    5053/ FFD6:                                ORG   ROMBS+$1FD6
    5054/ FFD6:                ;*** Vectors ***
    5055/ FFD6: 00 C4          VSCI            FDB   JSCI
    5056/ FFD8: 00 C7          VSPI            FDB   JSPI
    5057/ FFDA: 00 CA          VPAIE           FDB   JPAIE
    5058/ FFDC: 00 CD          VPAO            FDB   JPAO
    5059/ FFDE: 00 D0          VTOF            FDB   JTOF
    5060/ FFE0: 00 D3          VTOC5           FDB   JTOC5
    5061/ FFE2: 00 D6          VTOC4           FDB   JTOC4
    5062/ FFE4: 00 D9          VTOC3           FDB   JTOC3
    5063/ FFE6: 00 DC          VTOC2           FDB   JTOC2
    5064/ FFE8: 00 DF          VTOC1           FDB   JTOC1
    5065/ FFEA: 00 E2          VTIC3           FDB   JTIC3
    5066/ FFEC: 00 E5          VTIC2           FDB   JTIC2
    5067/ FFEE: 00 E8          VTIC1           FDB   JTIC1
    5068/ FFF0: 00 EB          VRTI            FDB   JRTI
    5069/ FFF2: 00 EE          VIRQ            FDB   JIRQ
    5070/ FFF4: 00 F1          VXIRQ           FDB   JXIRQ
    5071/ FFF6: 00 F4          VSWI            FDB   JSWI
    5072/ FFF8: 00 F7          VILLOP          FDB   JILLOP
    5073/ FFFA: 00 FA          VCOP            FDB   JCOP
    5074/ FFFC: 00 FD          VCLM            FDB   JCLM

    4725/ FD4C:
    4726/ FD4C:                ;**********
    4727/ FD4C:                ;*  byte() -  Read 2 ascii bytes from host and
    4728/ FD4C:                ;*convert to one hex byte.  Returns byte
    4729/ FD4C:                ;*shifted into shftreg and added to tmp4.
    4730/ FD4C:                ;**********
    4731/ FD4C: 37             BYTE            PSHB
    4732/ FD4D: 3C                             PSHX
    4733/ FD4E: BD FC 33       BYTE0           JSR   HOSTIN          ;read host (1st byte)
    4734/ FD51: 4D                             TSTA
    4735/ FD52: 27 FA                          BEQ   BYTE0           ;loop until input
    4736/ FD54: BD E2 01                       JSR   HEXBIN
    4737/ FD57: BD FC 33       BYTE1           JSR   HOSTIN          ;read host (2nd byte)
    4738/ FD5A: 4D                             TSTA
    4739/ FD5B: 27 FA                          BEQ   BYTE1           ;loop until input
    4740/ FD5D: BD E2 01                       JSR   HEXBIN
    4741/ FD60: 96 97                          LDAA  SHFTREG+1
    4742/ FD62: 9B C3                          ADDA  TMP4
    4743/ FD64: 97 C3                          STAA  TMP4            ;add to checksum
    4744/ FD66: 38                             PULX
    4745/ FD67: 33                             PULB
    4746/ FD68: 39                             RTS
    4747/ FD69:
    4748/ FD69:
    4749/ FD69:                ;**********
    4750/ FD69:                ;*   offset [<addr>]
    4751/ FD69:                ;* Specify offset to be added to s-record address when
    4752/ FD69:                ;* downloading from the host.
    4753/ FD69:                ;*  OFFSET                -show the current offset
    4754/ FD69:                ;*  OFFSET <data>         -current offset = data
    4755/ FD69:                ;*  OFFSET -<data>        -current offset = 0 - data
    4756/ FD69:                ;**********
    4757/ FD69:                ;*if(<data>) then offset = data;
    4758/ FD69:                ;*print(offset);
    4759/ FD69: =$FD69         OFFSET          EQU   *
    4760/ FD69: 7F 00 C3                       CLR   TMP4            ;minus indicator
    4761/ FD6C: BD E2 FC                       JSR   WSKIP
    4762/ FD6F: 27 28                          BEQ   OFFST3          ;jump if cr (no argument)
    4763/ FD71: 81 2D                          CMPA  #'-'
    4764/ FD73: 26 09                          BNE   OFFST1          ;jump not -
    4765/ FD75: 7C 00 C3                       INC   TMP4            ;set minus sign flag
    4766/ FD78: BD E2 EE                       JSR   INCBUFF         ;move buffer pointer
    4767/ FD7B: BD E2 FC                       JSR   WSKIP
    4768/ FD7E: BD E2 34       OFFST1          JSR   BUFFARG         ;read argument
    4769/ FD81: 7D 00 A8                       TST   COUNT
    4770/ FD84: 27 1D                          BEQ   OFFSTER         ;jump if bad argument
    4771/ FD86: BD E2 FC                       JSR   WSKIP
    4772/ FD89: 26 18                          BNE   OFFSTER         ;jump if not cr
    4773/ FD8B: DC 96                          LDD   SHFTREG         ;get offset value
    4774/ FD8D: 7D 00 C3                       TST   TMP4
    4775/ FD90: 27 05                          BEQ   OFFST2          ;jump if positive
    4776/ FD92: CC 00 00                       LDD   #$0000          ;negative - sub from 0
    4777/ FD95: 93 96                          SUBD  SHFTREG
    4778/ FD97: DD AC          OFFST2          STD   LDOFFST
    4779/ FD99: BD E4 F5       OFFST3          JSR   OUTCRLF         ;display current offset
    4780/ FD9C: CE 00 AC                       LDX   #LDOFFST
    4781/ FD9F: BD E4 E9                       JSR   OUT2BSP
    4782/ FDA2: 39                             RTS
    4783/ FDA3:
    4784/ FDA3: CE E6 98       OFFSTER         LDX   #MSG9           ;"bad argument"

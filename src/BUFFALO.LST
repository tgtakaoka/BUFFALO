    4807/ FDAA:                ;*          x[]++;
    4808/ FDAA:                ;*     incbuff(); a = wskip();
    4809/ FDAA:                ;*     if(a != cr) return(bad argument);
    4810/ FDAA:
    4811/ FDAA: CE E1 BE       REGISTER        LDX   #REGLIST
    4812/ FDAD: BD E2 FC                       JSR   WSKIP           ; a = first char of arg
    4813/ FDB0: BD E1 A7                       JSR   UPCASE          ;convert to upper case
    4814/ FDB3: 81 0D                          CMPA  #$D
    4815/ FDB5: 27 1C                          BEQ   REG4            ;jump if no argument
    4816/ FDB7: A1 00          REG1            CMPA  0,X
    4817/ FDB9: 27 0E                          BEQ   REG3
    4818/ FDBB: E6 00                          LDAB  0,X
    4819/ FDBD: 08                             INX
    4820/ FDBE: C1 53                          CMPB  #'S'
    4821/ FDC0: 26 F5                          BNE   REG1            ;jump if not "s"
    4822/ FDC2: CE E6 98       REG2            LDX   #MSG9           ;"bad argument"
    4823/ FDC5: BD E5 05                       JSR   OUTSTRG
    4824/ FDC8: 39                             RTS
    4825/ FDC9: 3C             REG3            PSHX
    4826/ FDCA: BD E2 EE                       JSR   INCBUFF
    4827/ FDCD: BD E2 FC                       JSR   WSKIP           ;next char after arg
    4828/ FDD0: 38                             PULX
    4829/ FDD1: 26 EF                          BNE   REG2            ;jump if not cr

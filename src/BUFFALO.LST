    3880/ F51A: A1 04          DISRCH1         CMPA  4,X             ;test opcode
    3881/ F51C: 26 0F                          BNE   DISRCH3         ;jump not this entry
    3882/ F51E: 5D                             TSTB
    3883/ F51F: 27 04                          BEQ   DISRCH2         ;jump if class=null
    3884/ F521: E1 05                          CMPB  5,X             ;test class
    3885/ F523: 26 08                          BNE   DISRCH3         ;jump not this entry
    3886/ F525: E6 05          DISRCH2         LDAB  5,X

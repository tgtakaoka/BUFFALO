    1803/ E8F5: BD E2 34                       JSR   BUFFARG
    1804/ E8F8: BD E2 FC                       JSR   WSKIP
    1805/ E8FB: 27 07                          BEQ   MSLASH          ;jump if cr
    1806/ E8FD: CE E6 98                       LDX   #MSG9           ;"bad argument"
    1807/ E900: BD E5 05                       JSR   OUTSTRG
    1808/ E903: 39                             RTS
    1809/ E904: 7D 00 A8       MSLASH          TST   COUNT

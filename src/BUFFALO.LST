     407/ E169:
     408/ E169:                ;*****************
     409/ E169:                ;*   Search tables for command.  At this point,
     410/ E169:                ;* COMBUFF holds the command field to be executed,
     411/ E169:                ;* and B = # of characters in the command field.
     412/ E169:                ;* The command table holds the whole command name
     413/ E169:                ;* but only the first n characters of the command
     414/ E169:                ;* must match what is in COMBUFF where n is the
     415/ E169:                ;* number of characters entered by the user.
     416/ E169:                ;*****************
     417/ E169:                ;*count = b;
     418/ E169:                ;*ptr1 = comtabl;
     419/ E169:                ;*while(ptr1[0] != end of table)
     420/ E169:                ;*   ptr1 = next entry
     421/ E169:                ;*   for(b=1; b=count; b++)
     422/ E169:                ;*      if(ptr1[b] == combuff[b]) continue;
     423/ E169:                ;*      else error(not found);
     424/ E169:                ;*   execute task;
     425/ E169:                ;*  return();
     426/ E169:                ;*return(command not found);
     427/ E169:
     428/ E169: D7 A8          SRCH            STAB  COUNT           ;size of command entered
     429/ E16B: CE E5 3B                       LDX   #COMTABL        ;pointer to table
     430/ E16E: DF B0                          STX   PTR1            ;pointer to next entry
     431/ E170: DE B0          SRCH1           LDX   PTR1
     432/ E172: 18 CE 00 8E                    LDY   #COMBUFF        ;pointer to command buffer
     433/ E176: E6 00                          LDAB  0,X
     434/ E178: C1 FF                          CMPB  #$FF
     435/ E17A: 26 09                          BNE   SRCH2
     436/ E17C: CE E6 71                       LDX   #MSG2           ;"command not found"
     437/ E17F: BD E5 05                       JSR   OUTSTRG
     438/ E182: 7E E0 C8                       JMP   MAIN
     439/ E185: 3C             SRCH2           PSHX                  ;compute next table entry
     440/ E186: CB 03                          ADDB  #$3
     441/ E188: 3A                             ABX
     442/ E189: DF B0                          STX   PTR1
     443/ E18B: 38                             PULX
     444/ E18C: 5F                             CLRB
     445/ E18D: 5C             SRCHLP          INCB                  ;match characters loop
     446/ E18E: A6 01                          LDAA  1,X             ;read table
     447/ E190: 18 A1 00                       CMPA  0,Y             ;compare to combuff
     448/ E193: 26 DB                          BNE   SRCH1           ;try next entry
     449/ E195: 08                             INX                   ;move pointers
     450/ E196: 18 08                          INY
     451/ E198: D1 A8                          CMPB  COUNT
     452/ E19A: 2D F1                          BLT   SRCHLP          ;loop countu1 times
     453/ E19C: DE B0                          LDX   PTR1
     454/ E19E: 09                             DEX
     455/ E19F: 09                             DEX
     456/ E1A0: EE 00                          LDX   0,X             ;jump address from table
     457/ E1A2: AD 00          EXEC            JSR   0,X             ;call task as subroutine
     458/ E1A4: 7E E0 C8                       JMP   MAIN
     459/ E1A7:                ;*
     460/ E1A7:                ;*****************
     461/ E1A7:                ;*   UTILITY SUBROUTINES - These routines
     462/ E1A7:                ;* are called by any of the task routines.
     463/ E1A7:                ;*****************
     464/ E1A7:                ;*****************
     465/ E1A7:                ;*  UPCASE(a) - If the contents of A is alpha,
     466/ E1A7:                ;* returns a converted to uppercase.
     467/ E1A7:                ;*****************
     468/ E1A7: 81 61          UPCASE          CMPA  #'a'
     469/ E1A9: 2D 06                          BLT   UPCASE1         ;jump if < a
     470/ E1AB: 81 7A                          CMPA  #'z'
     471/ E1AD: 2E 02                          BGT   UPCASE1         ;jump if > z
     472/ E1AF: 80 20                          SUBA  #$20            ;convert
     473/ E1B1: 39             UPCASE1         RTS
     474/ E1B2:
     475/ E1B2:                ;*****************
     476/ E1B2:                ;*  BPCLR() - Clear all entries in the
     477/ E1B2:                ;* table of breakpoints.

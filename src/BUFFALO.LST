    1373/ E6DB:
    1374/ E6DB:                ;**********
    1375/ E6DB:                ;*   break [-][<addr>] . . .
    1376/ E6DB:                ;* Modifies the breakpoint table.  More than
    1377/ E6DB:                ;* one argument can be entered on the command
    1378/ E6DB:                ;* line but the table will hold only 4 entries.
    1379/ E6DB:                ;* 4 types of arguments are implied above:
    1380/ E6DB:                ;* break           Prints table contents.
    1381/ E6DB:                ;* break <addr>    Inserts <addr>.
    1382/ E6DB:                ;* break -<addr>   Deletes <addr>.
    1383/ E6DB:                ;* break -         Clears all entries.
    1384/ E6DB:                ;**********
    1385/ E6DB:                ;* while 1
    1386/ E6DB:                ;*     a = wskip();
    1387/ E6DB:                ;*     switch(a)
    1388/ E6DB:                ;*          case(cr):
    1389/ E6DB:                ;*               bprint(); return;
    1390/ E6DB:
    1391/ E6DB: BD E2 FC       BREAK           JSR   WSKIP
    1392/ E6DE: 26 04                          BNE   BRKDEL          ;jump if not cr
    1393/ E6E0: BD E7 72                       JSR   BPRINT          ;print table
    1394/ E6E3: 39                             RTS
    1395/ E6E4:
    1396/ E6E4:                ;*          case("-"):
    1397/ E6E4:                ;*               incbuff(); readbuff();
    1398/ E6E4:                ;*               if(dchek(a))          /* look for wspac or cr */
    1399/ E6E4:                ;*                    bpclr();
    1400/ E6E4:                ;*                    breaksw;
    1401/ E6E4:                ;*               a = buffarg();
    1402/ E6E4:                ;*               if( !dchek(a) ) return(bad argument);
    1403/ E6E4:                ;*               b = bpsrch();
    1404/ E6E4:                ;*               if(b >= 0)
    1405/ E6E4:                ;*                    brktabl[b] = 0;
    1406/ E6E4:                ;*               breaksw;
    1407/ E6E4:
    1408/ E6E4: 81 2D          BRKDEL          CMPA  #'-'
    1409/ E6E6: 26 31                          BNE   BRKDEF          ;jump if not -
    1410/ E6E8: BD E2 EE                       JSR   INCBUFF
    1411/ E6EB: BD E2 E7                       JSR   READBUFF
    1412/ E6EE: BD E3 17                       JSR   DCHEK
    1413/ E6F1: 26 06                          BNE   BRKDEL1         ;jump if not delimeter
    1414/ E6F3: BD E1 B2                       JSR   BPCLR           ;clear table
    1415/ E6F6: 7E E6 DB                       JMP   BREAK           ;do next argument
    1416/ E6F9: BD E2 34       BRKDEL1         JSR   BUFFARG         ;get address to delete
    1417/ E6FC: BD E3 17                       JSR   DCHEK
    1418/ E6FF: 27 07                          BEQ   BRKDEL2         ;jump if delimeter
    1419/ E701: CE E6 98                       LDX   #MSG9           ;"bad argument"
    1420/ E704: BD E5 05                       JSR   OUTSTRG
    1421/ E707: 39                             RTS
    1422/ E708: BD E7 81       BRKDEL2         JSR   BPSRCH          ;look for addr in table
    1423/ E70B: 5D                             TSTB
    1424/ E70C: 2B 08                          BMI   BRKDEL3         ;jump if not found
    1425/ E70E: CE 00 9C                       LDX   #BRKTABL
    1426/ E711: 3A                             ABX
    1427/ E712: 6F 00                          CLR   0,X             ;clear entry
    1428/ E714: 6F 01                          CLR   1,X
    1429/ E716: 7E E6 DB       BRKDEL3         JMP   BREAK           ;do next argument
    1430/ E719:
    1431/ E719:                ;*          default:
    1432/ E719:                ;*               a = buffarg();
    1433/ E719:                ;*               if( !dchek(a) ) return(bad argument);
    1434/ E719:                ;*               b = bpsrch();
